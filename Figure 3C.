  Dur_wd_cat          = "Weekday Sleep Duration (h)",
  Dur_we_cat          = "Weekend Sleep Duration",
  Sedentary_cat       = "Daily Sedentary Time",
  MET_cat             = "Physical Activity Level (MET)"
)

plot_ready <- raw_results %>%
  filter(plot_stratum == TRUE) %>%
  left_join(interaction_summary, by = "Subgroup") %>%
  mutate(
    Subgroup_Label = dplyr::recode(Subgroup, !!!label_map, .default = Subgroup)
  )

subgroup_order <- c(
  "Gender",
  "Age Group (Years)",
  "Body Mass Index (kg/m\u00b2)",
  "Weekday Sleep Duration (h)"
)

plot_ready <- plot_ready %>%
  mutate(Subgroup_Label = factor(Subgroup_Label, levels = subgroup_order))

final_plot_df <- data.frame()

for (sub in subgroup_order) {
  sub_data <- filter(plot_ready, Subgroup_Label == sub)
  if (nrow(sub_data) == 0) next
  
  # Header row now keeps P_raw directly
  header <- data.frame(
    Subgroup_Label = sub,
    Level          = sub,
    OR             = NA_real_,
    LCI            = NA_real_,
    UCI            = NA_real_,
    P_raw          = sub_data$P_raw[1],
    is_header      = TRUE,
    stringsAsFactors = FALSE
  )
  
  # Level rows also keep P_raw
  levels_df <- sub_data %>%
    mutate(is_header = FALSE) %>%
    select(
      Subgroup_Label,
      Level,
      OR   = estimate,
      LCI  = conf.low,
      UCI  = conf.high,
      P_raw,
      is_header
    )
  
  final_plot_df <- rbind(final_plot_df, header, levels_df)
}

final_plot_df <- final_plot_df %>%
  mutate(
    Plot_ID = rev(seq_len(n())),
    Stats_Label = ifelse(
      is_header,
      "",
      sprintf("%.2f (%.2f, %.2f)", OR, LCI, UCI)
    ),
    P_Int_Label = ifelse(
      is_header,
      ifelse(is.na(P_raw), "", sprintf("P for interaction = %.3f", P_raw)),
      ""
    ),
    Level_Final = ifelse(
      is_header,
      as.character(Level),
      paste0("  ", as.character(Level))
    )
  )

# ==============================================================================
# SECTION 8: Figure 3C Construction (TOP-JOURNAL FINAL VERSION)
# ==============================================================================

cat("\n>>> [5/6] Generating final Figure 3C...\n")

X_LEFT_TEXT  <- 0.055
X_STATS_TEXT <- 15
X_PINT_TEXT  <- 40

X_MIN <- 0.05
X_MAX <- 80

y_top <- max(final_plot_df$Plot_ID, na.rm = TRUE)

p_3C <- ggplot(final_plot_df, aes(x = OR, y = Plot_ID)) +
  
  # Reference line at OR = 1
  geom_vline(
    xintercept = 1,
    linetype = "dashed",
    color = "gray65",
    linewidth = 0.6
  ) +
  
  # Confidence intervals
  geom_errorbarh(
    data = subset(final_plot_df, !is_header),
    aes(xmin = LCI, xmax = UCI),
    linewidth = 0.75,
    color = "#2C3E50",
    height = 0.18
  ) +
  
  # Point estimates
  geom_point(
    data = subset(final_plot_df, !is_header),
    color = "#D55E00",
    size = 2.7,
    shape = 15
  ) +
  
  # Panel label
  annotate(
    "text",
    x = X_LEFT_TEXT,
    y = y_top + 0.9,
    label = "C",
    hjust = 0,
    vjust = 1,
    family = "Arial",
    fontface = "bold",
    size = 5
  ) +
  
  # Column headers
  annotate(
    "text",
    x = X_STATS_TEXT,
    y = y_top + 0.7,
    label = "aOR (95% CI)",
    hjust = 0,
    family = "Arial",
    fontface = "bold",
    size = 4.0
  ) +
  annotate(
    "text",
    x = X_PINT_TEXT,
    y = y_top + 0.7,
    label = "P for interaction",
    hjust = 0,
    family = "Arial",
    fontface = "bold",
    size = 4.0
  ) +
  
  # Left text column
  geom_text(
    aes(
      x = X_LEFT_TEXT,
      label = Level_Final,
      fontface = ifelse(is_header, "bold", "plain")
    ),
    hjust = 0,
    family = "Arial",
    size = 3.5
  ) +
  
  # OR column
  geom_text(
    aes(x = X_STATS_TEXT, label = Stats_Label),
    hjust = 0,
    family = "Arial",
    size = 3.3
  ) +
  
  # P-interaction column
  geom_text(
    aes(x = X_PINT_TEXT, label = P_Int_Label),
    hjust = 0,
    family = "Arial",
    size = 3.2,
    fontface = "italic",
    color = "#2C3E50"
  ) +
  
  scale_x_log10(
    breaks = c(0.5, 1, 2, 4, 8),
    limits = c(X_MIN, X_MAX),
    expand = c(0, 0)
  ) +
  
  scale_y_continuous(
    limits = c(0.5, y_top + 1.1),
    expand = c(0, 0)
  ) +
  
  labs(
    title = NULL,
    subtitle = NULL,
    caption = NULL,
    x = "Adjusted odds ratio (95% CI)",
    y = NULL
  ) +
  
  theme_void(base_size = 11) +
  theme(
    axis.line.x = element_line(color = "black", linewidth = 0.55),
    axis.text.x = element_text(
      size = 10,
      color = "black",
      margin = margin(t = 6)
    ),
    axis.ticks.x = element_line(color = "black", linewidth = 0.45),
    axis.title.x = element_text(
      size = 10.5,
      face = "bold",
      margin = margin(t = 10),
      hjust = 0.35
    ),
    plot.margin = margin(18, 16, 12, 16)
  ) +
  coord_cartesian(clip = "off")

# Optional preview
print(p_3C)

