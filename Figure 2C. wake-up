# 5.3 KNOT SENSITIVITY ANALYSIS (AIC COMPARISON)
cat("\n--- Knot Sensitivity Analysis (AIC Comparison) ---\n")

compare_knots <- function(outcome, var, design_obj) {
  cat(sprintf("\n[Sensitivity Analysis for: %s]\n", var))
  
  results <- data.frame(Knots = 3:5, AIC = NA, P_NonLinear = NA)
  
  for (k in 3:5) {
    # Fit model with k knots
    form <- as.formula(paste0(outcome, " ~ rcs(", var, ", ", k, ") + 
          RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 + smoke_status + DMDMARTZ + 
          BMI_value + AlcoholCategory + diabetes_status + hypertension_status + 
          work_status + MET_total + INDFMPIR + sedentary_min"))
    fit <- svyglm(form, design = design_obj, family = quasibinomial())
    
    # Extract AIC and Nonlinear P-value (from anova)
    results$AIC[results$Knots == k] <- AIC(fit)[1]
    
    # Capture the nonlinear P-value from the spline component
    # Using anova to compare linear vs rcs for each knot configuration
    lin_form <- as.formula(paste(outcome, "~", var, "+ RIDAGEYR + RIAGENDR + 
              RIDRETH1 + DMDEDUC2 + smoke_status + DMDMARTZ + BMI_value + 
              AlcoholCategory + diabetes_status + hypertension_status + work_status + 
              MET_total + INDFMPIR + sedentary_min"))
    lin_fit <- svyglm(lin_form, design = design_obj, family = quasibinomial())
    results$P_NonLinear[results$Knots == k] <- anova(lin_fit, fit)$p
  }
  
  print(results)
  cat("Note: A lower AIC indicates a better balance of fit and complexity.\n")
  return(results)
}

