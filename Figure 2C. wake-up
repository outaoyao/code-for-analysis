build_wakeup_panel <- function(data, panel_label = "C", base_size = 11) {
  
  plot_data <- data %>%
    mutate(
      time_type = factor(
        time_type,
        levels = c("weekday", "weekend"),
        labels = c("Weekday", "Weekend")
      )
    )
  
  # Determine y-axis range with modest padding
  y_min <- min(plot_data$lower, na.rm = TRUE)
  y_max <- max(plot_data$upper, na.rm = TRUE)
  
  y_min_round <- floor(y_min * 10) / 10
  y_max_round <- ceiling(y_max * 10) / 10
  
  y_range <- y_max_round - y_min_round
  if (y_range <= 0) y_range <- 0.5
  
  y_pad <- max(0.04, y_range * 0.06)
  
  p <- ggplot(plot_data, aes(x = hours, y = yhat, group = time_type)) +
    geom_ribbon(
      aes(ymin = lower, ymax = upper, fill = time_type),
      alpha = alpha_ci,
      colour = NA
    ) +
    geom_hline(
      yintercept = 1,
      linetype = "dashed",
      colour = "grey35",
      linewidth = 0.5
    ) +
    geom_line(
      aes(colour = time_type),
      linewidth = 0.95
    ) +
    scale_colour_manual(
      values = color_scheme,
      name = "Schedule",
      guide = "none"
    ) +
    scale_fill_manual(
      values = color_scheme,
      name = "Schedule",
      guide = "none"
    ) +
    scale_x_continuous(
      name = "Wake-up timing (hours past midnight)",
      breaks = seq(0, 24, by = 4),
      limits = c(0, 24),
      expand = expansion(mult = c(0.01, 0.01))
    ) +
    scale_y_continuous(
      name = "Modeled odds ratio (95% CI)",
      limits = c(y_min_round - y_pad, y_max_round + y_pad),
      expand = expansion(mult = c(0, 0))
    ) +
    annotate(
      "text",
      x = 0.5,
      y = y_max_round + y_pad * 0.65,
      label = panel_label,
      hjust = 0,
      vjust = 1,
      family = "Arial",
      fontface = "bold",
      size = 5
    ) +
    journal_theme(base_size = base_size)
  
  return(p)
}

