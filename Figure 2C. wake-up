cat("\n=== TABLE: RCS-DERIVED EXPOSURE INTERVALS BY RISK SCORE ===\n")

summarize_wake_intervals <- function(rcs_data, label) {
  # 1. Identify Optimal Nadir
  nadir_idx <- which.min(rcs_data$yhat)
  nadir_hr  <- rcs_data$hours[nadir_idx]
  nadir_or  <- rcs_data$yhat[nadir_idx]
  
  cat(sprintf("\nTiming Type: %s\n", label))
  cat(sprintf("Optimal Nadir: %.2f hours past midnight (Lowest OR: %.4f)\n", nadir_hr, nadir_or))
  
  # 2. Map scores to all spline data points for interval extraction
  rcs_data$score <- sapply(rcs_data$hours, map_or_to_score, rcs_plot_data = rcs_data)
  
  # 3. Summarize intervals by score
  summary_tab <- rcs_data %>%
    group_by(score) %>%
    summarise(
      Start_Hour = min(hours),
      End_Hour   = max(hours),
      .groups = 'drop'
    ) %>%
    mutate(Gradient = c("Reference (Nadir Zone)", "Mild Elevation", "Moderate Elevation", "High Elevation")[score + 1])
  
  print(as.data.frame(summary_tab))
}

