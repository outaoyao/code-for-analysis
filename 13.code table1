# 10. Print Summary Statistics -------------------------------------------------
cat("\n--- SUMMARY STATISTICS ---\n")
cat("Total sample size (unweighted):", total_unweighted, "\n")
cat("No Depression group:", depression_dist["No Depression"], "\n")
cat("With Depression group:", depression_dist["With Depression"], "\n")

# Create summary of significant variables
cat("\nSignificant variables (P < 0.05):\n")
p_value_rows <- final_table[final_table$P_Value != "" & final_table$P_Value != "NA", ]
significant_vars <- p_value_rows[p_value_rows$P_Value != "" & p_value_rows$P_Value != "NA", ]

sig_vars_list <- c()
for (i in 1:nrow(significant_vars)) {
  var_name <- significant_vars$Variable[i]
  p_val <- significant_vars$P_Value[i]
  
  if (p_val == "<0.001" || (p_val != "NA" && as.numeric(p_val) < 0.05)) {
    sig_vars_list <- c(sig_vars_list, paste0(var_name, " (P = ", p_val, ")"))
  }
}

if (length(sig_vars_list) > 0) {
  for (i in seq_along(sig_vars_list)) {
    cat(sprintf("%2d. %s\n", i, sig_vars_list[i]))
  }
} else {
  cat("No significant variables found.\n")
}

