library(ggplot2)
library(dplyr)

# ==============================================================================
# COLOR PALETTE — Okabe-Ito (color-blind safe)
# ==============================================================================
COL_MODEL <- "#E69F00"   # orange  — Models 1–4
COL_STD   <- "#0072B2"   # blue    — Standardized OR
COL_SHADE <- "#EEF2F7"   # soft blue-grey alternating rows

# ==============================================================================
# 1. OR extraction with confint() (t-distribution CIs)
# ==============================================================================
extract_or_robust <- function(model, label, var_name = "CMB_Score") {
  cf  <- summary(model)$coefficients
  est <- cf[var_name, 1]
  pv  <- cf[var_name, 4]
  
  ci_log <- tryCatch(
    confint(model)[var_name, ],
    error = function(e) {
      se <- cf[var_name, 2]
      c(est - 1.96 * se, est + 1.96 * se)
    }
  )
  
  data.frame(
    Model = label,
    OR    = round(exp(est),       2),
    LCI   = round(exp(ci_log[1]), 2),
    UCI   = round(exp(ci_log[2]), 2),
    P_val = pv,
    stringsAsFactors = FALSE
  )
}

# ==============================================================================
# 2. Build plot_data
# ==============================================================================
plot_data <- rbind(
  extract_or_robust(model1,  "Model 1: Unadjusted"),
  extract_or_robust(model2,  "Model 2: Demographic-adjusted"),
  extract_or_robust(model3,  "Model 3: Lifestyle-adjusted"),
  extract_or_robust(model4,  "Model 4: Fully adjusted"),
  extract_or_robust(model_z, "Standardized OR\n(per 1-SD increase)",
                    var_name = "Score_z")
) %>%
  mutate(
    CI_label = sprintf("%.2f (%.2f\u2013%.2f)", OR, LCI, UCI),
    P_label  = case_when(
      P_val < 0.001 ~ "<.001",
      TRUE          ~ sprintf("%.3f", P_val)
    ),
    is_std   = grepl("Standardized", Model),
    pt_col   = ifelse(is_std, COL_STD, COL_MODEL),
    pt_shp   = ifelse(is_std, 18L, 15L),
    pt_size  = ifelse(is_std, 5.5, 4.0)
  )

n              <- nrow(plot_data)
plot_data$y_pos <- seq(n, 1, by = -1)
y_header       <- n + 0.90

# ==============================================================================
# 3. X-axis layout — extended rightward for wide CI of Standardized OR
#    Standardized OR UCI ≈ 1.71 → data zone needs to reach at least 1.75
# ==============================================================================
X_MIN      <- 0.85
X_DATA_MAX <- 1.80   # extended from 1.60
X_CI       <- 1.87   # text columns shift right accordingly
X_P        <- 2.28
X_MAX      <- 2.72

# ==============================================================================
# 4. Alternating row shading
# ==============================================================================
shade_df <- plot_data %>%
  filter(y_pos %% 2 == 0) %>%
  transmute(ymin = y_pos - 0.5, ymax = y_pos + 0.5)

# ==============================================================================
# 5. Corrected P-for-trend value
#    NOTE: p_trend = 0.01072 from model output — NOT <0.001
# ==============================================================================
p_trend_label <- paste0("P for linear trend = 0.011")

# ==============================================================================
# 6. Build ggplot
# ==============================================================================
p <- ggplot(plot_data, aes(x = OR, y = y_pos)) +
  
  # ── Alternating row shading ──────────────────────────────────────────────────
  geom_rect(
    data = shade_df,
    aes(xmin = X_MIN, xmax = X_DATA_MAX, ymin = ymin, ymax = ymax),
    fill = COL_SHADE, alpha = 0.60,
    inherit.aes = FALSE
  ) +
  
  # ── Dotted separator: model rows vs standardized OR ──────────────────────────
  geom_hline(yintercept = 1.5, linetype = "dotted",
             color = "gray45", linewidth = 0.55) +
  
  # ── Vertical divider: data zone | text zone ──────────────────────────────────
  annotate("segment",
           x = X_DATA_MAX, xend = X_DATA_MAX,
           y = 0.4, yend = n + 0.55,
           color = "gray70", linewidth = 0.35) +
  
  # ── Reference line OR = 1 ────────────────────────────────────────────────────
  geom_vline(xintercept = 1, linetype = "dashed",
             color = "gray25", linewidth = 0.70) +
  
  # ── CI error bars ────────────────────────────────────────────────────────────
  geom_errorbar(
    aes(xmin = LCI, xmax = UCI, color = pt_col, y = y_pos),
    orientation = "y",
    width = 0.22, linewidth = 0.95
  ) +
  
  # ── Point estimates ──────────────────────────────────────────────────────────
  geom_point(
    aes(color = pt_col, shape = factor(pt_shp), size = pt_size)
  ) +
  
  # ── P-for-trend annotation (bottom-right of data zone) ───────────────────────
  annotate("text",
           x = X_DATA_MAX - 0.02, y = 0.62,
           label = p_trend_label,
           hjust = 1, vjust = 0,
           size = 3.0, fontface = "italic", color = "#555555") +
  
  # ── Column header: aOR (95% CI) ──────────────────────────────────────────────
  annotate("text",
           x = X_CI, y = y_header,
           label = "aOR (95% CI)", hjust = 0,
           size = 3.8, fontface = "bold", color = "black") +
  
  # ── Column header: P-value ───────────────────────────────────────────────────
  annotate("text",
           x = X_P, y = y_header,
           label = "P-value", hjust = 0,
           size = 3.8, fontface = "bold", color = "black") +
  
  # ── aOR (95% CI) per row ─────────────────────────────────────────────────────
  geom_text(
    data = plot_data,
    aes(x = X_CI, y = y_pos, label = CI_label),
    hjust = 0, size = 3.35, color = "black", inherit.aes = FALSE
  ) +
  
  # ── P-value per row ──────────────────────────────────────────────────────────
  geom_text(
    data = plot_data,
    aes(x = X_P, y = y_pos, label = P_label),
    hjust = 0, size = 3.2, color = "#333333",
    fontface = "italic", inherit.aes = FALSE
  ) +
  
  # ── Scales ───────────────────────────────────────────────────────────────────
  scale_y_continuous(
    breaks = plot_data$y_pos,
    labels = plot_data$Model,
    limits = c(0.35, n + 1.25),
    expand = c(0, 0)
  ) +
  scale_x_continuous(
    limits = c(X_MIN, X_MAX),
    breaks = c(0.9, 1.0, 1.1, 1.2, 1.3, 1.4, 1.5, 1.6, 1.7),
    expand = c(0, 0)
  ) +
  scale_color_identity() +
  scale_shape_manual(values = c("15" = 15, "18" = 18), guide = "none") +
  scale_size_identity() +
  
  # ── Labels ───────────────────────────────────────────────────────────────────
  labs(
    title    = paste0(
      "Association Between Cumulative Circadian Misalignment Score ",
      "and Moderate-to-Severe Depressive Symptoms"
    ),
    subtitle = paste0(
      "Adjusted Odds Ratios (95% CI) \u2014 Survey-Weighted Logistic Regression (NHANES) ",
      "\u2014 Sensitivity Analysis (Outcome: PHQ-9 \u2265 10)"
    ),
    x        = "Adjusted Odds Ratio (95% CI)  |  per 1-unit increase in Cumulative Circadian Misalignment Score",
    y        = NULL,
    caption  = paste0(
      "\u25a0  Orange squares (Models 1\u20134): aOR per 1-unit increase in CMB Score (continuous).\n",
      "\u25c6  Blue diamond: standardized aOR per 1-SD increase (fully adjusted model); ",
      "wide CI reflects lower outcome prevalence.\n",
      "CIs derived from t-distribution (confint()). ",
      "P for linear trend = 0.011 (weighted quartiles as ordinal predictor, fully adjusted).\n",
      "Survey weights: NHANES MEC sample weights. Color palette: Okabe-Ito (color-blind safe)."
    )
  ) +
  
  # ── Theme ────────────────────────────────────────────────────────────────────
  theme_classic(base_size = 11) +
  theme(
    plot.title      = element_text(size = 12.5, face = "bold",
                                   hjust = 0, margin = margin(b = 4)),
    plot.subtitle   = element_text(size = 9.2, color = "#444444",
                                   hjust = 0, margin = margin(b = 9),
                                   lineheight = 1.3),
    plot.caption    = element_text(size = 7.8, color = "#666666",
                                   hjust = 0, lineheight = 1.55,
                                   margin = margin(t = 10)),
    axis.text.y     = element_text(size = 10, color = "black",
                                   hjust = 1, lineheight = 1.25),
    axis.text.x     = element_text(size = 9,  color = "black"),
    axis.title.x    = element_text(size = 8.8, margin = margin(t = 7)),
    axis.line.x     = element_line(color = "black", linewidth = 0.5),
    axis.line.y     = element_blank(),
    axis.ticks.y    = element_blank(),
    legend.position = "none",
    plot.margin     = margin(t = 14, r = 22, b = 14, l = 14)
  ) +
  coord_cartesian(clip = "off")

