library(purrr)
library(broom)

# 2. Results Extraction Function -----------------------------------------------
# Purpose: Extract adjusted Odds Ratios (aOR) and formatted p-values.
extract_or <- function(model, label, var_name = "CMB_Score") {
  coef_summary <- summary(model)$coefficients
  
  if (!var_name %in% rownames(coef_summary)) {
    stop(paste("Error: Target variable", var_name, "not found in model results."))
  }
  
  est   <- coef_summary[var_name, 1]
  se    <- coef_summary[var_name, 2]
  p_val <- coef_summary[var_name, 4]
  
  OR    <- exp(est)
  LCI   <- exp(est - 1.96 * se)
  UCI   <- exp(est + 1.96 * se)
  
  # Standard academic P-value formatting (e.g., <.001)
  p_formatted <- format.pval(p_val, digits = 3, eps = 0.001)
  
  data.frame(
    Model = label, 
    aOR   = round(OR, 3), 
    Lower = round(LCI, 3), 
    Upper = round(UCI, 3), 
    P     = p_formatted,
    stringsAsFactors = FALSE
  )
}

# 3. Data Integration & Pre-processing -----------------------------------------
cat("\n>>> Step 1: Merging analytic datasets... <<<\n")
data_base    <- readRDS("D:/code/12.Dataset.rds")
score_mid    <- readRDS("D:/code/14.Sleep_midpoint.rds") %>% select(SEQN, sleep_midpoint_total_score)
score_onset  <- readRDS("D:/code/15.onset.rds") %>% select(SEQN, onset_total_score)
score_wakeup <- readRDS("D:/code/16.wake-up.rds") %>% select(SEQN, wake_total_score)

nhanes_final <- data_base %>%
  left_join(score_mid, by = "SEQN") %>%
  left_join(score_onset, by = "SEQN") %>%
  left_join(score_wakeup, by = "SEQN") %>%
  mutate(CMB_Score = sleep_midpoint_total_score + onset_total_score + wake_total_score)

# Academic Factorization
nhanes_final <- nhanes_final %>%
  mutate(across(c(RIAGENDR, RIDRETH1, DMDEDUC2, smoke_status, DMDMARTZ, 
                  Alcohol_Status, diabetes_status, htn_status, work_status), as.factor))

# 4. Survey Design Specification -----------------------------------------------
cat("\n>>> Step 2: Configuring Survey Weights (MEC weights)... <<<\n")
design_base <- svydesign(id = ~SDMVPSU, strata = ~SDMVSTRA, weights = ~mec_adj, 
                         data = nhanes_final, nest = TRUE)

# 5. Formal Weight-Adjusted Quartile Construction ------------------------------
cat("\n>>> Step 3: Deriving Weighted Quartiles (svyquantile)... <<<\n")

# Use svyquantile to ensure cut points reflect the US general population
q_cuts <- svyquantile(~CMB_Score, design_base, quantiles = c(0, 0.25, 0.5, 0.75, 1), na.rm = TRUE)
q_values <- as.numeric(q_cuts$CMB_Score[,1])

# Incorporate the Weighted Quartile into the Design Object
design_final <- update(design_base, 
                       CMB_Q = cut(CMB_Score, breaks = q_values, include.lowest = TRUE, labels = FALSE),
                       Score_z = as.numeric(scale(CMB_Score))
)

# Explicitly ensure CMB_Trend is treated as an ordinal numeric variable for trend testing
design_final <- update(design_final, CMB_Trend = as.numeric(CMB_Q))

# 6. Hierarchical Regression Analysis ------------------------------------------
cat("\n>>> Step 4: Hierarchical Modeling... <<<\n")

# Model 1: Unadjusted
model1 <- svyglm(ModSevere_depression_above ~ CMB_Score, design = design_final, family = quasibinomial())

# Model 2: Adjusted for basic demographics
model2 <- svyglm(ModSevere_depression_above ~ CMB_Score + RIDAGEYR + RIAGENDR + RIDRETH1, 
                 design = design_final, family = quasibinomial())

# Model 3: Adjusted for demographics + lifestyle/socioeconomics
model3 <- svyglm(ModSevere_depression_above ~ CMB_Score + RIDAGEYR + RIAGENDR + RIDRETH1 + 
                   DMDEDUC2 + smoke_status + DMDMARTZ + BMI_value + Alcohol_Status + 
                   diabetes_status + htn_status + work_status + MET_total + INDFMPIR, 
                 design = design_final, family = quasibinomial())

# Model 4: Fully Adjusted (Model 3 + Sedentary behavior)
model4 <- svyglm(ModSevere_depression_above ~ CMB_Score + RIDAGEYR + RIAGENDR + RIDRETH1 + 
                   DMDEDUC2 + smoke_status + DMDMARTZ + BMI_value + Alcohol_Status + 
                   diabetes_status + htn_status + work_status + MET_total + INDFMPIR + 
                   sedentary_min, design = design_final, family = quasibinomial())

# Consolidated Table Construction
results_summary <- rbind(
  extract_or(model1, "Model 1: Crude"),
  extract_or(model2, "Model 2: Demographic-adjusted"),
  extract_or(model3, "Model 3: Lifestyle-adjusted"),
  extract_or(model4, "Model 4: Fully adjusted")
)
print(results_summary)

# 7. Standardized Effect and P-for-trend ---------------------------------------
cat("\n>>> Step 5: Advanced Statistical Testing... <<<\n")

# A. Standardized OR (per 1 SD increase)
model_z <- svyglm(ModSevere_depression_above ~ Score_z + RIDAGEYR + RIAGENDR + RIDRETH1 + 
                    DMDEDUC2 + smoke_status + DMDMARTZ + BMI_value + Alcohol_Status + 
                    diabetes_status + htn_status + work_status + MET_total + 
                    INDFMPIR + sedentary_min, design = design_final, family = quasibinomial())

res_z <- extract_or(model_z, "Standardized OR (per 1-SD increase)", "Score_z")

# B. Formal Linear Trend Test (using Quartiles as ordinal values)
model_trend <- svyglm(ModSevere_depression_above ~ CMB_Trend + RIDAGEYR + RIAGENDR + RIDRETH1 + 
                        DMDEDUC2 + smoke_status + DMDMARTZ + BMI_value + Alcohol_Status + 
                        diabetes_status + htn_status + work_status + MET_total + 
                        INDFMPIR + sedentary_min, design = design_final, family = quasibinomial())

p_trend <- summary(model_trend)$coefficients["CMB_Trend", 4]

# Final Outputs
print(res_z)
cat("\nFormal P-for-trend (Linear Trend Test):", format.pval(p_trend, eps = 0.001), "\n")

