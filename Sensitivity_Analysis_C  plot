  scale_x_continuous(limits = c(X_MIN, X_MAX), breaks = seq(0.9,1.5,0.1), expand = c(0,0)) +
  scale_color_identity() +
  scale_shape_manual(values = c("15"=15,"18"=18), guide="none") +
  scale_size_identity() +
  labs(x = "Adjusted odds ratio (95% CI)", y = NULL) +
  theme_classic(base_size = 11) +
  theme(axis.text.y = element_text(size=10, color="black", hjust=1, lineheight=1.25),
