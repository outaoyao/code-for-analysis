  "diabetes_status + hypertension_status + work_status + MET_total + INDFMPIR"
)

adj_full_plus <- paste(adj_full_core, "+ sedentary_min")

make_formula <- function(exposure, covariates = NULL) {
  rhs <- if (is.null(covariates)) exposure else paste(exposure, "+", covariates)
  as.formula(paste(OUTCOME_VAR, "~", rhs))
}

# ==============================================================================
# SECTION 5: Helper functions
# ==============================================================================

get_pool_df <- function(mi_obj) {
  sm <- summary(mi_obj)
  out <- as.data.frame(sm)
  out$term <- rownames(out)
  rownames(out) <- NULL
  
  if ("results" %in% names(out)) out$estimate <- out$results
  if ("se" %in% names(out)) out$std.error <- out$se
  if ("(lower" %in% names(out)) out$conf.low <- out$`(lower`
  if ("upper)" %in% names(out)) out$conf.high <- out$`upper)`
  
  out
}

extract_one_term <- function(mi_obj, term_name, label) {
  out <- get_pool_df(mi_obj)
  row <- out %>% filter(term == term_name)
  
  if (nrow(row) != 1) {
    stop("Target term not found: ", term_name)
  }
  
  tibble(
    Model = label,
    beta = row$estimate,
    se = row$std.error,
    OR = exp(row$estimate),
    LCI = exp(row$conf.low),
    UCI = exp(row$conf.high)
  )
}

extract_pattern_terms <- function(mi_obj, exposure_pattern) {
  out <- get_pool_df(mi_obj)
  
  out %>%
    filter(str_detect(term, exposure_pattern)) %>%
    mutate(
      OR = exp(estimate),
      LCI = exp(conf.low),
      UCI = exp(conf.high)
    ) %>%
    select(term, estimate, std.error, conf.low, conf.high, OR, LCI, UCI, missInfo)
}

fmt_or <- function(or, lci, uci, digits = 2) {
  sprintf(
    paste0("%.", digits, "f (%.", digits, "f-%.", digits, "f)"),
    or, lci, uci
  )
}

fmt_p <- function(p) {
  if (is.na(p)) return(NA_character_)
  if (p < 0.001) return("<.001")
  sprintf("%.3f", p)
}

# More rigorous pooled P-value display:
# derive a two-sided Wald P-value directly from pooled estimate and pooled SE
# This aligns the displayed P-value with the MI-pooled OR and CI.
extract_pooled_term <- function(mi_obj, term_name, label) {
  out <- get_pool_df(mi_obj)
  row <- out %>% filter(term == term_name)
  
  if (nrow(row) != 1) {
    stop("Target term not found in pooled model output: ", term_name)
  }
  
  z_val <- row$estimate / row$std.error
  p_val <- 2 * pnorm(-abs(z_val))
  
  tibble(
    Model = label,
    estimate = row$estimate,
    se = row$std.error,
    OR = exp(row$estimate),
    LCI = exp(row$conf.low),
    UCI = exp(row$conf.high),
    P_val = p_val,
    P_label = fmt_p(p_val)
  )
}

