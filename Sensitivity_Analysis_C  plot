  annotate("text", x = X_P, y = y_header, label = "P-value", hjust = 0,
           size = 3.8, fontface = "bold", color = "black") +
  geom_text(aes(x = X_CI, y = y_pos_plot, label = CI_label),
            data = plot_data_C, hjust = 0, size = 3.35, color = "black", inherit.aes = FALSE) +
  geom_text(aes(x = X_P, y = y_pos_plot, label = P_label),
            data = plot_data_C, hjust = 0, size = 3.2, color = "#2C2C2C", fontface = "italic", inherit.aes = FALSE) +
  scale_y_continuous(breaks = plot_data_C$y_pos, labels = plot_data_C$Model,
