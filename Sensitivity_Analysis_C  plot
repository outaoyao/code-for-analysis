# SECTION 2: Ensure PHQ-8 >= 9 outcome exists and redefine grouped score
# New categories: 0-4, 5-7, 8-10, 11-13, 14+
# ==============================================================================

complete_list_scored <- lapply(complete_list_scored, function(df) {
  
  if (!"PHQ8_depression_above_9" %in% names(df)) {
    if (!"PHQ8_SCORE" %in% names(df)) {
      stop("Neither PHQ8_depression_above_9 nor PHQ8_SCORE was found in the dataset.")
    }
    
    df <- df %>%
      mutate(
        PHQ8_depression_above_9 = case_when(
          PHQ8_SCORE >= 9 ~ 1,
          PHQ8_SCORE < 9  ~ 0,
          TRUE ~ NA_real_
        )
      )
  }
  
  if (!"PHQ8_depression_above_10" %in% names(df) && "PHQ8_SCORE" %in% names(df)) {
    df <- df %>%
      mutate(
        PHQ8_depression_above_10 = case_when(
          PHQ8_SCORE >= 10 ~ 1,
          PHQ8_SCORE < 10  ~ 0,
          TRUE ~ NA_real_
        )
      )
  }
  
  df %>%
    mutate(
      sleep_timing_total_group = cut(
        sleep_timing_total_score,
        breaks = c(-Inf, 4, 7, 10, 13, Inf),
        labels = c("0-4", "5-7", "8-10", "11-13", "14+"),
        right = TRUE
      ),
      sleep_timing_total_group = factor(
        sleep_timing_total_group,
        levels = c("0-4", "5-7", "8-10", "11-13", "14+")
      )
    )
})

