# =========================================================
# Figure 1. Flowchart of participant selection
# NHANES 2017-2023 | Main analysis
# Export: TIFF 600 dpi + PNG 300 dpi (proof)
# Output folder: D:/code
# NO caption inside the figure (per journal style guidelines)
# All legend text in "Figure Legends" section of manuscript
# =========================================================
# Run once to install packages:
# install.packages(c("DiagrammeR", "DiagrammeRsvg", "rsvg", "magick"))

library(DiagrammeR)
library(DiagrammeRsvg)
library(rsvg)
library(magick)

# ── 1. Output folder & file paths ─────────────────────────
out_dir <- "D:/code"
if (!dir.exists(out_dir)) dir.create(out_dir, recursive = TRUE)

out_tiff <- file.path(out_dir, "Figure_1_flowchart_main_analysis.tiff")
out_png  <- file.path(out_dir, "Figure_1_flowchart_main_analysis.png")
tmp_svg  <- tempfile(fileext = ".svg")

# ── 2. Resolution settings ────────────────────────────────
fig_width_in  <- 8.5    # inches — fits single-column and 2-column layouts
fig_height_in <- 11.5   # inches
dpi_hires     <- 600    # line-art / flowchart: >= 600 dpi (journal requirement)
dpi_proof     <- 300    # PNG proof

px_w_hi <- round(fig_width_in  * dpi_hires)   # 5100 px
px_h_hi <- round(fig_height_in * dpi_hires)   # 6900 px
px_w_lo <- round(fig_width_in  * dpi_proof)   # 2550 px
px_h_lo <- round(fig_height_in * dpi_proof)   # 3450 px

# ── 3. DOT graph specification ────────────────────────────
# Visual conventions:
#   Inclusion boxes  : white fill, navy border, centre column
#   Exclusion boxes  : amber fill, rust border, dashed arrows, right column
#   Final sample box : light-blue fill, bold navy border
#   Outcome boxes    : green / red borders, bottom row
#   fontsize 22-25   : prints at ~11-12 pt at 600 dpi / 8.5 in, crisp at 100%

gr <- grViz("
digraph flowchart {

  graph [
    layout   = dot,
    rankdir  = TB,
    bgcolor  = white,
    nodesep  = 0.55,
    ranksep  = 0.75,
    margin   = '0.35,0.25',
    splines  = ortho
  ]

  # -- Default node style (inclusion boxes) ----------------
  node [
    shape     = box,
    style     = 'rounded,filled',
    fillcolor = white,
    color     = '#1A1A2E',
    fontname  = Helvetica,
    fontsize  = 22,
    penwidth  = 1.8,
    margin    = '0.24,0.16',
    width     = 5.0
  ]

  edge [
    color     = '#1A1A2E',
    penwidth  = 1.6,
    arrowsize = 0.95,
    arrowhead = vee
  ]

  # -- Inclusion nodes -------------------------------------
  n1 [label    = 'Total participants in NHANES 2017-2023\n(N = 27,493)',
      fontsize = 24,
      penwidth = 2.2]

  n3 [label = 'Participants with complete PHQ-9 data\n(N = 13,731)']

  n5 [label = 'Participants with complete PHQ-9\nand sleep-related data (N = 13,454)']

  n7 [label     = 'Final analytic sample\n(N = 10,137)',
      fillcolor = '#E8F1FB',
      color     = '#1B4F8A',
      penwidth  = 2.4,
      fontsize  = 25,
      style     = 'rounded,filled,bold']

  # -- Exclusion nodes (right column) ----------------------
  node [
    shape     = box,
    style     = 'rounded,dashed,filled',
    fillcolor = '#F5F5F5',
    color     = '#7A7A7A',
    fontname  = Helvetica,
    fontsize  = 20,
    penwidth  = 1.4,
    margin    = '0.20,0.14',
    width     = 3.8
  ]

  ex1 [label = 'Excluded: missing PHQ-9 data\n(n = 13,762)']
  ex2 [label = 'Excluded: missing sleep-related data\n(n = 277)']
  ex3 [label = 'Excluded:\nPregnancy (n = 110)\nMissing covariates (n = 3,207)']

  # -- Outcome nodes (bottom row) --------------------------
  node [
    shape     = box,
    style     = 'rounded,filled',
    fontname  = Helvetica,
    fontsize  = 21,
    penwidth  = 1.8,
    margin    = '0.22,0.16',
    width     = 3.6
  ]

  n8 [label     = 'Without depressive symptoms\n(n = 9,178)',
      fillcolor = '#E6F0FF',
      color     = '#0072B2']

  n9 [label     = 'With depressive symptoms\n(n = 959)',
      fillcolor = '#FFEBD6',
      color     = '#D55E00']

  # -- Main vertical flow (solid arrows) -------------------
  n1 -> n3 -> n5 -> n7

  # -- Exclusion arrows (dashed, rust) ---------------------
  edge [color = '#B7451A', penwidth = 1.3,
        arrowhead = vee, style = dashed]
  n1 -> ex1
  n3 -> ex2
  n5 -> ex3

  # -- Outcome split (solid) --------------------------------
  edge [color = '#1A1A2E', penwidth = 1.6,
        arrowhead = vee, style = solid]
  n7 -> n8
  n7 -> n9

  # -- Rank constraints ------------------------------------
  { rank = same; n1; ex1 }
  { rank = same; n3; ex2 }
  { rank = same; n5; ex3 }
  { rank = same; n8; n9  }
}
")

# ── 4. Render SVG to temp file ────────────────────────────
svg_txt <- export_svg(gr)
writeLines(svg_txt, con = tmp_svg)   # image_read_svg() requires a file path
svg_raw <- charToRaw(svg_txt)        # rsvg_png() accepts raw bytes

# ── 5. Export PNG proof @ 300 dpi ─────────────────────────
rsvg_png(
  svg    = svg_raw,
  file   = out_png,
  width  = px_w_lo,
  height = px_h_lo
)
message(sprintf("[OK] PNG  -> %s  (%d x %d px @ %d dpi)",
                out_png, px_w_lo, px_h_lo, dpi_proof))

# ── 6. Export TIFF @ 600 dpi, LZW lossless ───────────────
img <- image_read_svg(tmp_svg, width = px_w_hi, height = px_h_hi)
img <- image_convert(img, format = "tiff", colorspace = "sRGB")
image_write(
  image       = img,
  path        = out_tiff,
  format      = "tiff",
  density     = paste0(dpi_hires, "x", dpi_hires),
  compression = "lzw"
)
message(sprintf("[OK] TIFF -> %s  (%d x %d px @ %d dpi)",
                out_tiff, px_w_hi, px_h_hi, dpi_hires))

# ── 7. Clean up temp SVG ──────────────────────────────────
unlink(tmp_svg)
message("[OK] Temp SVG removed.")
message(sprintf("[DONE] Files saved to: %s", out_dir))

