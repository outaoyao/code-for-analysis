    bg = "white"
  )
  
  message(sprintf("[OK] TIFF: %s", path_tiff))
  message(sprintf("[OK] PNG : %s", path_png))
  message(sprintf("[OK] PDF : %s", path_pdf))
}

# ------------------------------------------------------------------------------
# Helper: format p-value for figure annotation
# ------------------------------------------------------------------------------
fmt_p_fig <- function(p) {
  if (is.na(p))  return(NA_character_)
  if (p < 0.001) return("< 0.001")
  sprintf("= %.3f", p)
}

# ------------------------------------------------------------------------------
# Helper: get p-values by model label
# ------------------------------------------------------------------------------
get_pvals <- function(model_label) {
  list(
    p_overall = overall_tests %>%
      filter(Model == model_label) %>%
      pull(p_value),
    p_nonlin = nonlin_tests %>%
      filter(Model == model_label) %>%
      pull(p_value)
  )
}

# ------------------------------------------------------------------------------
# Core plotting function
# ------------------------------------------------------------------------------
make_rcs_figure <- function(pred_df, panel_label,
                            p_overall, p_nonlin,
                            show_overall = FALSE) {
  
  p_nonlin_txt <- paste0("P for nonlinearity ", fmt_p_fig(p_nonlin))
  
  p_ann_label <- if (show_overall) {
    paste0(
      "P for overall association ", fmt_p_fig(p_overall), "\n",
      p_nonlin_txt
    )
  } else {
    p_nonlin_txt
  }
  
  y_min_raw <- min(pred_df$LCI, na.rm = TRUE)
  y_max_raw <- max(pred_df$UCI, na.rm = TRUE)
  
  y_min_r <- floor(y_min_raw * 10) / 10
  y_max_r <- ceiling(y_max_raw * 10) / 10
  
  y_range <- y_max_r - y_min_r
  if (y_range <= 0) y_range <- 0.5
  y_pad <- max(0.04, y_range * 0.06)
  
  x_min <- min(pred_df$x, na.rm = TRUE)
  x_max <- max(pred_df$x, na.rm = TRUE)
  
  ggplot(pred_df, aes(x = x, y = OR)) +
    geom_ribbon(
      aes(ymin = LCI, ymax = UCI),
      fill   = COL_LINE,
      alpha  = ALPHA_RIB,
      colour = NA
    ) +
    geom_line(
      colour = COL_LINE,
      linewidth = 1.15
    ) +
    geom_hline(
      yintercept = 1,
      linetype   = "dashed",
      colour     = "grey35",
      linewidth  = 0.6
    ) +
    annotate(
      "text",
      x        = x_min + 0.03 * (x_max - x_min),
      y        = y_max_r + y_pad * 0.72,
      label    = panel_label,
      hjust    = 0,
      vjust    = 1,
      family   = "sans",
      fontface = "bold",
      size     = 5,
      colour   = "black"
    ) +
    annotate(
      "text",
      x        = x_max - 0.02 * (x_max - x_min),
      y        = y_max_r + y_pad * 0.10,
      label    = p_ann_label,
      hjust    = 1,
      vjust    = 1,
      family   = "sans",
      fontface = "plain",
      size     = 3.5,
      colour   = "black",
      lineheight = 1.2
    ) +
    scale_x_continuous(
      name   = "Cumulative circadian misalignment score (higher = greater misalignment)",
      expand = expansion(mult = c(0.01, 0.01))
    ) +
    scale_y_continuous(
      name   = "Adjusted odds ratio (95% CI)",
      limits = c(y_min_r - y_pad, y_max_r + y_pad),
      expand = expansion(mult = c(0, 0))
    ) +
    labs(
      title = NULL,
      subtitle = NULL,
      caption = NULL
    ) +
    theme_bw(base_size = BASE_SIZE, base_family = "sans") +
    theme(
      panel.grid.major  = element_blank(),
      panel.grid.minor  = element_blank(),
      panel.border      = element_rect(colour = "black", linewidth = 0.7, fill = NA),
      axis.title        = element_text(face = "bold", colour = "black", size = BASE_SIZE),
      axis.text         = element_text(colour = "black", size = BASE_SIZE * 0.9),
      axis.ticks        = element_line(colour = "black", linewidth = 0.4),
      axis.ticks.length = unit(2.5, "pt"),
      plot.title        = element_blank(),
      plot.subtitle     = element_blank(),
      plot.caption      = element_blank(),
      legend.position   = "none",
      plot.margin       = margin(t = 10, r = 10, b = 8, l = 8)
    )
}

