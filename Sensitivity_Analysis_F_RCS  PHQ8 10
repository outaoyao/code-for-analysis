# ==============================================================================
# SECTION 12: Secondary analysis using categorized exposure
# ==============================================================================

if (!is.na(risk_escalation_point)) {
  
  mi_cat_datasets <- lapply(complete_list_scored, function(df) {
    df %>%
      mutate(
        RCS_Risk_Group = ifelse(sleep_timing_total_score >= risk_escalation_point, 1, 0),
        RCS_Risk_Group = factor(
          RCS_Risk_Group,
          levels = c(0, 1),
          labels = c(
            paste0("Lower Exposure (<", round(risk_escalation_point, 2), ")"),
            paste0("Higher Exposure (>=", round(risk_escalation_point, 2), ")")
          )
        )
      )
  })
  
  fit_cat_secondary <- lapply(mi_cat_datasets, function(df) {
    design_tmp <- svydesign(
      id = ~SDMVPSU,
      strata = ~SDMVSTRA,
      weights = ~mec_adj,
      data = df,
      nest = TRUE
    )
    
    svyglm(
      as.formula(
        paste(
          OUTCOME_VAR,
          "~ RCS_Risk_Group +",
          adj_full_plus
        )
      ),
      design = design_tmp,
      family = quasibinomial()
    )
  })
  
  pool_cat_secondary <- MIcombine(fit_cat_secondary)
  pool_cat_secondary_df <- summary(pool_cat_secondary) %>%
    as.data.frame()
  
  pool_cat_secondary_df$term <- rownames(pool_cat_secondary_df)
  rownames(pool_cat_secondary_df) <- NULL
  
  if ("results" %in% names(pool_cat_secondary_df)) pool_cat_secondary_df$estimate <- pool_cat_secondary_df$results
  if ("se" %in% names(pool_cat_secondary_df)) pool_cat_secondary_df$std.error <- pool_cat_secondary_df$se
  if ("(lower" %in% names(pool_cat_secondary_df)) pool_cat_secondary_df$conf.low <- pool_cat_secondary_df$`(lower`
  if ("upper)" %in% names(pool_cat_secondary_df)) pool_cat_secondary_df$conf.high <- pool_cat_secondary_df$`upper)`
  
  secondary_row <- pool_cat_secondary_df %>%
    filter(str_detect(term, "RCS_Risk_Group")) %>%
    mutate(
      OR = exp(estimate),
      LCI = exp(conf.low),
      UCI = exp(conf.high)
    )
  
  z_secondary <- secondary_row$estimate / secondary_row$std.error
  p_secondary <- 2 * pnorm(-abs(z_secondary))
  
  secondary_summary <- tibble(
    term = secondary_row$term,
    OR = secondary_row$OR,
    LCI = secondary_row$LCI,
    UCI = secondary_row$UCI,
    P_value = p_secondary,
    CI_label = fmt_or(secondary_row$OR, secondary_row$LCI, secondary_row$UCI),
    P_label = fmt_p(p_secondary)
  )
  
  cat("============================================================\n")
  cat("SECONDARY ANALYSIS USING RCS-DERIVED CATEGORIZED EXPOSURE\n")
  cat("============================================================\n")
  print(secondary_summary)
  cat("\n")
  
