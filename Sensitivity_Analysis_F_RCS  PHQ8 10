fmt_or <- function(or, lci, uci, digits = 2) {
  sprintf(
    paste0("%.", digits, "f (%.", digits, "f-%.", digits, "f)"),
    or, lci, uci
  )
}

fmt_p <- function(p) {
  if (is.na(p)) return(NA_character_)
  if (p < 0.001) return("<0.001")
  sprintf("%.3f", p)
}

build_rcs_basis_df <- function(x, knots) {
  basis <- as.data.frame(rcspline.eval(x, knots = knots, inclx = TRUE))
  names(basis) <- c("rcs_lin", paste0("rcs_nonlin", seq_len(ncol(basis) - 1)))
  basis
}

build_model_data <- function(df, xvar, knots) {
  basis_df <- build_rcs_basis_df(df[[xvar]], knots)
  bind_cols(df, basis_df)
}

pool_coef_vcov <- function(fit_list) {
  m <- length(fit_list)
  
  coef_list <- lapply(fit_list, coef)
  vcov_list <- lapply(fit_list, vcov)
  
  coef_names <- names(coef_list[[1]])
  
  Q <- do.call(cbind, coef_list)
  qbar <- rowMeans(Q)
  
  Ubar <- Reduce(`+`, vcov_list) / m
  
  centered <- lapply(coef_list, function(b) {
    matrix(b - qbar, ncol = 1)
  })
  B <- Reduce(`+`, lapply(centered, function(d) d %*% t(d))) / (m - 1)
  
  Tmat <- Ubar + (1 + 1 / m) * B
  
  rownames(Tmat) <- coef_names
  colnames(Tmat) <- coef_names
  
  list(
    coef = qbar,
    vcov = Tmat,
    coef_names = coef_names,
    m = m
  )
}

wald_test_terms <- function(beta, vcov_mat, term_names) {
  b <- beta[term_names]
  V <- vcov_mat[term_names, term_names, drop = FALSE]
  
  stat <- as.numeric(t(b) %*% solve(V) %*% b)
  df <- length(term_names)
  p <- pchisq(stat, df = df, lower.tail = FALSE)
  
  tibble(
    chisq = stat,
    df = df,
    p_value = p
  )
}

make_rcs_formula <- function(outcome, covariates = NULL) {
  rhs_terms <- c("rcs_lin", "rcs_nonlin1", "rcs_nonlin2")
  if (!is.null(covariates)) {
    rhs_terms <- c(rhs_terms, covariates)
  }
  as.formula(paste(outcome, "~", paste(rhs_terms, collapse = " + ")))
}

fit_rcs_on_dataset <- function(df, formula_obj) {
  design <- svydesign(
    id = ~SDMVPSU,
    strata = ~SDMVSTRA,
    weights = ~mec_adj,
    data = df,
    nest = TRUE
  )
  
  svyglm(formula_obj, design = design, family = quasibinomial())
}

predict_pooled_rcs <- function(pool_obj, x_grid, ref_value, knots, baseline_df, covariate_formula) {
  grid_basis <- build_rcs_basis_df(x_grid, knots)
  ref_basis  <- build_rcs_basis_df(ref_value, knots)
  
  newdata_grid <- bind_cols(
    baseline_df[rep(1, length(x_grid)), , drop = FALSE],
    grid_basis
  )
  
  newdata_ref <- bind_cols(
    baseline_df[rep(1, 1), , drop = FALSE],
    ref_basis
  )
  
  mm_grid <- model.matrix(covariate_formula, data = newdata_grid)
  mm_ref  <- model.matrix(covariate_formula, data = newdata_ref)
  
  beta <- pool_obj$coef
  V    <- pool_obj$vcov
  
  diff_mat <- sweep(mm_grid, 2, mm_ref[1, ], FUN = "-")
  log_or   <- as.numeric(diff_mat %*% beta)
  
  se_log_or <- apply(diff_mat, 1, function(d) {
    sqrt(as.numeric(t(d) %*% V %*% d))
  })
  
  tibble(
    x = x_grid,
    log_or = log_or,
    OR = exp(log_or),
    LCI = exp(log_or - 1.96 * se_log_or),
    UCI = exp(log_or + 1.96 * se_log_or)
  )
}

make_reference_row <- function(df) {
  ref <- df %>%
    summarise(
      RIDAGEYR = median(RIDAGEYR, na.rm = TRUE),
      BMI_value = median(BMI_value, na.rm = TRUE),
      MET_total = median(MET_total, na.rm = TRUE),
      INDFMPIR = median(INDFMPIR, na.rm = TRUE),
      sedentary_min = median(sedentary_min, na.rm = TRUE)
    )
  
  get_mode <- function(x) {
    ux <- na.omit(x)
    names(sort(table(ux), decreasing = TRUE))[1]
  }
  
  ref$RIAGENDR <- factor(get_mode(df$RIAGENDR), levels = levels(df$RIAGENDR))
  ref$RIDRETH1 <- factor(get_mode(df$RIDRETH1), levels = levels(df$RIDRETH1))
  ref$DMDEDUC2 <- factor(get_mode(df$DMDEDUC2), levels = levels(df$DMDEDUC2))
  ref$smoke_status <- factor(get_mode(df$smoke_status), levels = levels(df$smoke_status))
  ref$DMDMARTZ <- factor(get_mode(df$DMDMARTZ), levels = levels(df$DMDMARTZ))
  ref$AlcoholCategory <- factor(get_mode(df$AlcoholCategory), levels = levels(df$AlcoholCategory))
  ref$diabetes_status <- factor(get_mode(df$diabetes_status), levels = levels(df$diabetes_status))
  ref$hypertension_status <- factor(get_mode(df$hypertension_status), levels = levels(df$hypertension_status))
  ref$work_status <- factor(get_mode(df$work_status), levels = levels(df$work_status))
  
  ref
}

