    tab_options(table.font.names          = c("Times New Roman", "Arial", "Helvetica", "sans"),
                table.font.size           = px(18),
                column_labels.font.weight = "bold")
  gtsave(pvalue_gt, file.path(base_path, "Table_S3_Pvalues_RCS_PHQ9_ge10.html"))
  cat("Formatted HTML table saved.\n\n")
}

