# ---- 2a. Confirm or derive PHQ9_depression_above_10 -------------------------
if (!"PHQ9_depression_above_10" %in% names(data_phq9)) {
  
  # Try to derive from a raw PHQ-9 total score column.
  # Adjust the column name below if your dataset uses a different name.
  phq9_score_col <- intersect(
    names(data_phq9),
    c("PHQ9_SCORE", "PHQ9_score", "phq9_score", "PHQ9SCORE")
  )
  
  if (length(phq9_score_col) == 0) {
    stop(paste(
      "PHQ9_depression_above_10 not found in", input_phq9_file,
      "and no recognised PHQ-9 total score column was detected.",
      "Please check the column names in that file."
    ))
  }
  
  sc <- phq9_score_col[1]
  message("Deriving PHQ9_depression_above_10 from column: ", sc)
  
  data_phq9 <- data_phq9 %>%
    mutate(
      PHQ9_depression_above_10 = case_when(
        .data[[sc]] >= 10 ~ 1L,
        .data[[sc]] <  10 ~ 0L,
        TRUE ~ NA_integer_
      )
    )
}

cat("PHQ9_depression_above_10 prevalence (source file):\n")
print(table(data_phq9$PHQ9_depression_above_10, useNA = "ifany"))
cat("\n")

# ---- 2b. Identify the participant ID for merging ----------------------------
# We need a key that exists in BOTH the MI datasets and data_phq9.
# Common NHANES identifiers: SEQN.  Adjust if yours differs.
id_candidates <- intersect(
  names(complete_list_raw[[1]]),
  names(data_phq9)
)
id_candidates <- id_candidates[id_candidates %in% c("SEQN", "seqn", "ID", "id")]

if (length(id_candidates) == 0) {
  stop(paste(
    "No common participant ID column (e.g., SEQN) found between the MI",
    "datasets and", input_phq9_file,
    ". Please specify the merge key manually."
  ))
}

merge_key <- id_candidates[1]
cat("Merging on column:", merge_key, "\n\n")

# ---- 2c. Keep only the key + outcome from the PHQ-9 file --------------------
phq9_merge <- data_phq9 %>%
  select(all_of(c(merge_key, "PHQ9_depression_above_10"))) %>%
  distinct(across(all_of(merge_key)), .keep_all = TRUE)

# ==============================================================================
# SECTION 3: Merge PHQ-9 outcome into every imputed dataset
# ==============================================================================

complete_list_scored <- lapply(complete_list_raw, function(df) {
  
  # Drop pre-existing column if present (avoid .x / .y conflicts)
  if ("PHQ9_depression_above_10" %in% names(df)) {
    df <- df %>% select(-PHQ9_depression_above_10)
  }
  
  df <- df %>%
    left_join(phq9_merge, by = merge_key)
  
  df
})

# Quick check on merge success
