# Harrell-style 4-knot locations from first imputed dataset
x_ref      <- complete_list_scored[[1]][[EXPOSURE_VAR]]
knots_rcs  <- as.numeric(quantile(x_ref, probs = c(0.05, 0.35, 0.65, 0.95), na.rm = TRUE))
