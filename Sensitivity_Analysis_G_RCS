# ==============================================================================
# SECTION 5: Helper functions
# ==============================================================================

fmt_or <- function(or, lci, uci, digits = 2) {
  sprintf(paste0("%.", digits, "f (%.", digits, "f-%.", digits, "f)"),
          or, lci, uci)
}

fmt_p <- function(p) {
  if (is.na(p)) return(NA_character_)
  if (p < 0.001) return("<0.001")
  sprintf("%.3f", p)
}

fmt_p_fig <- function(p) {
  if (is.na(p))  return(NA_character_)
  if (p < 0.001) return("< 0.001")
  sprintf("= %.3f", p)
}

build_rcs_basis_df <- function(x, knots) {
  basis <- as.data.frame(rcspline.eval(x, knots = knots, inclx = TRUE))
  names(basis) <- c("rcs_lin", paste0("rcs_nonlin", seq_len(ncol(basis) - 1)))
  basis
}

build_model_data <- function(df, xvar, knots) {
  bind_cols(df, build_rcs_basis_df(df[[xvar]], knots))
}

pool_coef_vcov <- function(fit_list) {
  m          <- length(fit_list)
  coef_list  <- lapply(fit_list, coef)
  vcov_list  <- lapply(fit_list, vcov)
  coef_names <- names(coef_list[[1]])
  Q          <- do.call(cbind, coef_list)
  qbar       <- rowMeans(Q)
  Ubar       <- Reduce(`+`, vcov_list) / m
  centered   <- lapply(coef_list, function(b) matrix(b - qbar, ncol = 1))
  B          <- Reduce(`+`, lapply(centered, function(d) d %*% t(d))) / (m - 1)
  Tmat       <- Ubar + (1 + 1 / m) * B
  rownames(Tmat) <- coef_names; colnames(Tmat) <- coef_names
  list(coef = qbar, vcov = Tmat, coef_names = coef_names, m = m)
}

wald_test_terms <- function(beta, vcov_mat, term_names) {
  b    <- beta[term_names]
  V    <- vcov_mat[term_names, term_names, drop = FALSE]
  stat <- as.numeric(t(b) %*% solve(V) %*% b)
  df   <- length(term_names)
  tibble(chisq = stat, df = df, p_value = pchisq(stat, df, lower.tail = FALSE))
}

make_rcs_formula <- function(outcome, covariates = NULL) {
  rhs <- c("rcs_lin", "rcs_nonlin1", "rcs_nonlin2")
  if (!is.null(covariates)) rhs <- c(rhs, covariates)
  as.formula(paste(outcome, "~", paste(rhs, collapse = " + ")))
}

fit_rcs_on_dataset <- function(df, formula_obj) {
  design <- svydesign(id = ~SDMVPSU, strata = ~SDMVSTRA,
                      weights = ~mec_adj, data = df, nest = TRUE)
  svyglm(formula_obj, design = design, family = quasibinomial())
}

predict_pooled_rcs <- function(pool_obj, x_grid, ref_value, knots,
                               baseline_df, covariate_formula) {
  grid_basis <- build_rcs_basis_df(x_grid, knots)
  ref_basis  <- build_rcs_basis_df(ref_value, knots)
  
  newdata_grid <- bind_cols(baseline_df[rep(1, length(x_grid)), , drop = FALSE], grid_basis)
  newdata_ref  <- bind_cols(baseline_df[rep(1, 1),              , drop = FALSE], ref_basis)
  
  mm_grid <- model.matrix(covariate_formula, data = newdata_grid)
  mm_ref  <- model.matrix(covariate_formula, data = newdata_ref)
  
  beta     <- pool_obj$coef
  V        <- pool_obj$vcov
  diff_mat <- sweep(mm_grid, 2, mm_ref[1, ], FUN = "-")
  log_or   <- as.numeric(diff_mat %*% beta)
  
  se_log_or <- apply(diff_mat, 1, function(d) sqrt(as.numeric(t(d) %*% V %*% d)))
  
  tibble(x = x_grid, log_or = log_or,
         OR  = exp(log_or),
         LCI = exp(log_or - 1.96 * se_log_or),
         UCI = exp(log_or + 1.96 * se_log_or))
}

make_reference_row <- function(df) {
  ref <- df %>%
    summarise(RIDAGEYR     = median(RIDAGEYR,     na.rm = TRUE),
              BMI_value    = median(BMI_value,    na.rm = TRUE),
              MET_total    = median(MET_total,    na.rm = TRUE),
              INDFMPIR     = median(INDFMPIR,     na.rm = TRUE),
              sedentary_min= median(sedentary_min,na.rm = TRUE))
  
  get_mode <- function(x) {
    ux <- na.omit(x)
    names(sort(table(ux), decreasing = TRUE))[1]
  }
  
  for (fv in c("RIAGENDR","RIDRETH1","DMDEDUC2","smoke_status","DMDMARTZ",
               "AlcoholCategory","diabetes_status","hypertension_status","work_status")) {
    ref[[fv]] <- factor(get_mode(df[[fv]]), levels = levels(df[[fv]]))
  }
  ref
}

# ==============================================================================
# SECTION 6: Build RCS basis for all imputed datasets
# ==============================================================================

mi_rcs_datasets <- lapply(complete_list_scored, build_model_data,
                          xvar = EXPOSURE_VAR, knots = knots_rcs)
cat("Spline basis created for all imputed datasets.\n\n")

# ==============================================================================
# SECTION 7: Fit spline models across imputations
# ==============================================================================

cat("Fitting survey-weighted RCS models...\n")

formula_m1 <- make_rcs_formula(OUTCOME_VAR, NULL)
formula_m2 <- make_rcs_formula(OUTCOME_VAR, adj_demographic)
formula_m3 <- make_rcs_formula(OUTCOME_VAR, adj_full_core)
formula_m4 <- make_rcs_formula(OUTCOME_VAR, adj_full_plus)

fit_m1_list <- lapply(mi_rcs_datasets, fit_rcs_on_dataset, formula_obj = formula_m1)
fit_m2_list <- lapply(mi_rcs_datasets, fit_rcs_on_dataset, formula_obj = formula_m2)
fit_m3_list <- lapply(mi_rcs_datasets, fit_rcs_on_dataset, formula_obj = formula_m3)
fit_m4_list <- lapply(mi_rcs_datasets, fit_rcs_on_dataset, formula_obj = formula_m4)

cat("Model fitting complete.\n\n")

# ==============================================================================
# SECTION 8: Pool coefficients and covariance matrices
# ==============================================================================

cat("Pooling across imputations...\n")
pool_m1 <- pool_coef_vcov(fit_m1_list)
pool_m2 <- pool_coef_vcov(fit_m2_list)
pool_m3 <- pool_coef_vcov(fit_m3_list)
pool_m4 <- pool_coef_vcov(fit_m4_list)
cat("Pooling complete.\n\n")

# ==============================================================================
# SECTION 9: Wald tests — overall association and non-linearity
# ==============================================================================

spline_terms  <- c("rcs_lin", "rcs_nonlin1", "rcs_nonlin2")
nonlin_terms  <- c("rcs_nonlin1", "rcs_nonlin2")
model_labels  <- c("Model 1: Unadjusted",
                   "Model 2: Demographic-adjusted",
                   "Model 3: Lifestyle-adjusted",
                   "Model 4: Fully adjusted")
pool_list     <- list(pool_m1, pool_m2, pool_m3, pool_m4)

overall_tests <- map2_dfr(pool_list, model_labels, function(p, lab) {
  wald_test_terms(p$coef, p$vcov, spline_terms) %>% mutate(Model = lab)
}) %>% mutate(P_label = sapply(p_value, fmt_p))

nonlin_tests <- map2_dfr(pool_list, model_labels, function(p, lab) {
  wald_test_terms(p$coef, p$vcov, nonlin_terms) %>% mutate(Model = lab)
}) %>% mutate(P_label = sapply(p_value, fmt_p))

cat("============================================================\n")
cat("OVERALL ASSOCIATION TESTS (PHQ-9 >= 10)\n")
cat("============================================================\n")
print(overall_tests %>% select(Model, chisq, df, p_value, P_label))
cat("\n")

cat("============================================================\n")
cat("NON-LINEARITY TESTS (PHQ-9 >= 10)\n")
cat("============================================================\n")
print(nonlin_tests %>% select(Model, chisq, df, p_value, P_label))
cat("\n")

# ==============================================================================
# SECTION 10: Pooled spline predictions for Model 4
# ==============================================================================

baseline_row <- make_reference_row(mi_rcs_datasets[[1]])

x_grid <- seq(
  from       = quantile(mi_rcs_datasets[[1]][[EXPOSURE_VAR]], 0.01, na.rm = TRUE),
  to         = quantile(mi_rcs_datasets[[1]][[EXPOSURE_VAR]], 0.99, na.rm = TRUE),
  length.out = 300
)

plot_formula_m4 <- as.formula(
  paste("~ rcs_lin + rcs_nonlin1 + rcs_nonlin2 +", adj_full_plus)
)

rcs_pred_m4 <- predict_pooled_rcs(
  pool_obj          = pool_m4,
  x_grid            = x_grid,
  ref_value         = ref_value,
  knots             = knots_rcs,
  baseline_df       = baseline_row,
  covariate_formula = plot_formula_m4
)

# ==============================================================================
# SECTION 11: Nadir and risk-escalation point
# ==============================================================================

pred_data   <- arrange(rcs_pred_m4, x)
nadir_row   <- pred_data %>% filter(OR == min(OR, na.rm = TRUE)) %>% slice(1)
nadir_value <- nadir_row$x[1]

risk_escalation_row <- pred_data %>%
  filter(x > nadir_value, OR >= 1.10) %>%
  slice(1)

if (nrow(risk_escalation_row) > 0) {
  risk_escalation_point <- risk_escalation_row$x[1]
  cat("[Nadir Point]:", round(nadir_value, 4), "\n")
  cat("[Risk-Escalation Point]: OR >= 1.10 at score =",
      round(risk_escalation_point, 4), "\n\n")
} else {
  risk_escalation_point <- NA_real_
  cat("No OR >= 1.10 detected after nadir.\n\n")
}

# ==============================================================================
# SECTION 12: Secondary analysis — categorized exposure
# ==============================================================================

if (!is.na(risk_escalation_point)) {
  
  mi_cat_datasets <- lapply(complete_list_scored, function(df) {
    df %>%
      mutate(
        RCS_Risk_Group = factor(
          ifelse(sleep_timing_total_score >= risk_escalation_point, 1L, 0L),
          levels = c(0L, 1L),
          labels = c(
            paste0("Lower Exposure (<",  round(risk_escalation_point, 2), ")"),
            paste0("Higher Exposure (>=", round(risk_escalation_point, 2), ")")
          )
        )
      )
  })
  
  fit_cat_list <- lapply(mi_cat_datasets, function(df) {
    des <- svydesign(id = ~SDMVPSU, strata = ~SDMVSTRA,
                     weights = ~mec_adj, data = df, nest = TRUE)
    svyglm(as.formula(paste(OUTCOME_VAR, "~ RCS_Risk_Group +", adj_full_plus)),
           design = des, family = quasibinomial())
  })
  
  pool_cat      <- MIcombine(fit_cat_list)
  pool_cat_df   <- summary(pool_cat) %>% as.data.frame()
  pool_cat_df$term <- rownames(pool_cat_df); rownames(pool_cat_df) <- NULL
  
  # Harmonise column names across mitools versions
  if ("results"  %in% names(pool_cat_df)) pool_cat_df$estimate  <- pool_cat_df$results
  if ("se"       %in% names(pool_cat_df)) pool_cat_df$std.error <- pool_cat_df$se
  if ("(lower"   %in% names(pool_cat_df)) pool_cat_df$conf.low  <- pool_cat_df$`(lower`
  if ("upper)"   %in% names(pool_cat_df)) pool_cat_df$conf.high <- pool_cat_df$`upper)`
  
  secondary_row <- pool_cat_df %>%
    filter(str_detect(term, "RCS_Risk_Group")) %>%
    mutate(OR  = exp(estimate),
           LCI = exp(conf.low),
           UCI = exp(conf.high))
  
  z_sec <- secondary_row$estimate / secondary_row$std.error
  
  secondary_summary <- tibble(
    term     = secondary_row$term,
    OR       = secondary_row$OR,
    LCI      = secondary_row$LCI,
    UCI      = secondary_row$UCI,
    P_value  = 2 * pnorm(-abs(z_sec)),
    CI_label = fmt_or(secondary_row$OR, secondary_row$LCI, secondary_row$UCI),
    P_label  = fmt_p(2 * pnorm(-abs(z_sec)))
  )
  
  cat("============================================================\n")
  cat("SECONDARY ANALYSIS — RCS-DERIVED CATEGORIZED EXPOSURE\n")
  cat("============================================================\n")
  print(secondary_summary)
  cat("\n")
  
} else {
  secondary_summary <- NULL
}

