COL_LINE_G <- "#0072B2"   # Okabe-Ito blue — colorblind-safe
ALPHA_RIB  <- 0.16
BASE_SIZE  <- 11
FIG_W      <- 6.0
FIG_H      <- 4.8

# ------------------------------------------------------------------------------
# Export helper (reusable)
# ------------------------------------------------------------------------------
export_figure <- function(plot_obj, stem) {
  
  path_tiff <- file.path(out_dir, paste0(stem, ".tiff"))
  path_png  <- file.path(out_dir, paste0(stem, ".png"))
  path_pdf  <- file.path(out_dir, paste0(stem, ".pdf"))
  
  ggsave(path_tiff, plot = plot_obj, device = "tiff",
         dpi = 600, width = FIG_W, height = FIG_H,
         units = "in", compression = "lzw", bg = "white")
  
  ggsave(path_png,  plot = plot_obj, device = "png",
         dpi = 300, width = FIG_W, height = FIG_H,
         units = "in", bg = "white")
  
  ggsave(path_pdf,  plot = plot_obj, device = cairo_pdf,
         width = FIG_W, height = FIG_H, units = "in", bg = "white")
  
  message(sprintf("[OK] TIFF : %s", path_tiff))
  message(sprintf("[OK] PNG  : %s", path_png))
  message(sprintf("[OK] PDF  : %s", path_pdf))
}

# ------------------------------------------------------------------------------
# Core figure constructor (parameterised color + label)
# ------------------------------------------------------------------------------
make_rcs_figure <- function(pred_df,
                            panel_label,
                            p_overall,
                            p_nonlin,
                            col_line     = "#0072B2",
                            show_overall = FALSE) {
  
  p_nonlin_txt <- paste0("P for nonlinearity ", fmt_p_fig(p_nonlin))
  p_ann_label  <- if (show_overall) {
    paste0("P for overall association ", fmt_p_fig(p_overall), "\n", p_nonlin_txt)
  } else {
    p_nonlin_txt
  }
  
  y_min_raw <- min(pred_df$LCI, na.rm = TRUE)
  y_max_raw <- max(pred_df$UCI, na.rm = TRUE)
  y_min_r   <- floor(y_min_raw   * 10) / 10
  y_max_r   <- ceiling(y_max_raw * 10) / 10
  y_range   <- max(y_max_r - y_min_r, 0.5)
  y_pad     <- max(0.04, y_range * 0.06)
  
  x_min <- min(pred_df$x, na.rm = TRUE)
  x_max <- max(pred_df$x, na.rm = TRUE)
  
  ggplot(pred_df, aes(x = x, y = OR)) +
    
    # Confidence ribbon
    geom_ribbon(aes(ymin = LCI, ymax = UCI),
                fill   = col_line,
                alpha  = ALPHA_RIB,
                colour = NA) +
    
    # Spline line
    geom_line(colour = col_line, linewidth = 1.15) +
    
    # Reference line at OR = 1
    geom_hline(yintercept = 1,
               linetype   = "dashed",
               colour     = "grey35",
               linewidth  = 0.6) +
    
    # Panel label (bold, top-left)
    annotate("text",
             x        = x_min + 0.03 * (x_max - x_min),
             y        = y_max_r + y_pad * 0.72,
             label    = panel_label,
             hjust    = 0, vjust = 1,
             family   = "sans", fontface = "bold",
             size     = 5, colour = "black") +
    
    # P-value annotation (top-right)
    annotate("text",
             x          = x_max - 0.02 * (x_max - x_min),
             y          = y_max_r + y_pad * 0.10,
             label      = p_ann_label,
             hjust      = 1, vjust = 1,
             family     = "sans", fontface = "plain",
             size       = 3.5, colour = "black",
             lineheight = 1.2) +
    
    scale_x_continuous(
      name   = "Cumulative circadian misalignment score (higher = greater misalignment)",
      expand = expansion(mult = c(0.01, 0.01))
    ) +
    scale_y_continuous(
      name   = "Adjusted odds ratio (95% CI)",
      limits = c(y_min_r - y_pad, y_max_r + y_pad),
      expand = expansion(mult = c(0, 0))
    ) +
    labs(title = NULL, subtitle = NULL, caption = NULL) +
    
    theme_bw(base_size = BASE_SIZE, base_family = "sans") +
    theme(
      panel.grid.major  = element_blank(),
      panel.grid.minor  = element_blank(),
      panel.border      = element_rect(colour = "black", linewidth = 0.7, fill = NA),
      axis.title        = element_text(face = "bold", colour = "black", size = BASE_SIZE),
