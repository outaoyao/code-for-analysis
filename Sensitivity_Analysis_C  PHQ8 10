# Weighted prevalence (first imputed dataset)
prev_tab <- svyby(
  ~PHQ8_depression_above_10,
  ~sleep_timing_total_group,
  design = design1,
  FUN    = svymean,
  vartype = c("ci"),
  na.rm  = TRUE
) %>%
  as.data.frame() %>%
  mutate(
    pct    = PHQ8_depression_above_10 * 100,
    ci_lo  = ci_l * 100,
    ci_hi  = ci_u * 100,
    prev_label = fmt_prev(pct, ci_lo, ci_hi)
  )

# Group labels and corresponding coefficient names in MI-pooled categorical model
groups <- list(
  list(grp = "0-4",   coef = NULL,                                                     ref = TRUE),
  list(grp = "5-7",   coef = "relevel(sleep_timing_total_group, ref = \"0-4\")5-7",   ref = FALSE),
  list(grp = "8-10",  coef = "relevel(sleep_timing_total_group, ref = \"0-4\")8-10",  ref = FALSE),
  list(grp = "11-13", coef = "relevel(sleep_timing_total_group, ref = \"0-4\")11-13", ref = FALSE),
  list(grp = "14+",   coef = "relevel(sleep_timing_total_group, ref = \"0-4\")14+",   ref = FALSE)
)

panel_C <- lapply(groups, function(g) {
  prev_row <- prev_tab[as.character(prev_tab$sleep_timing_total_group) == g$grp, ]
  prev_str <- if (nrow(prev_row) == 1) prev_row$prev_label else em
  
  if (g$ref) {
    data.frame(
      col1 = paste0("Score group ", g$grp, " (reference)"),
      col2 = prev_str,
      col3 = "1.00 (reference)",
      col4 = em,
      stringsAsFactors = FALSE
    )
  } else {
    r <- mi_or_row(pool_cat_m4, g$coef)
    data.frame(
      col1 = paste0("Score group ", g$grp),
      col2 = prev_str,
      col3 = fmt_or_ci(r$OR, r$LCI, r$UCI),
      col4 = fmt_p_mi(r$P),
      stringsAsFactors = FALSE
    )
  }
}) %>% bind_rows()

