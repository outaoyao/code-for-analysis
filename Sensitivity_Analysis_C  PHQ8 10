  col1 = sprintf("Standardized OR (per 1-SD = %.2f units)\u1d9c", sd_score),
  col2 = em,
  col3 = fmt_or_ci(r_z$OR, r_z$LCI, r_z$UCI),
  col4 = fmt_p_mi(r_z$P),
  stringsAsFactors = FALSE
)

