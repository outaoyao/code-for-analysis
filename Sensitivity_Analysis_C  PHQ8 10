# ── Formatting helpers ─────────────────────────────────────────────────────────
fmt_or_ci <- function(or, lci, uci) {
  sprintf("%.2f (%.2f\u2013%.2f)", or, lci, uci)
}

fmt_p_mi <- function(p) {
  if (is.na(p))    return("\u2014")
  if (p < 0.001)   return("<0.001")
  sprintf("%.3f", p)
}

fmt_prev <- function(pct, lo, hi) {
  sprintf("%.1f (%.1f\u2013%.1f)", pct, lo, hi)
}

em <- "\u2014"   # em-dash for empty cells

# ── MI-pooled P-value from pooled estimate and SE ────────────────────────────
mi_pval <- function(pool_obj, term_name) {
  sm  <- as.data.frame(summary(pool_obj))
  sm$term <- rownames(sm)
  row <- sm[sm$term == term_name, ]
  if (nrow(row) != 1) return(NA_real_)
  z <- row$results / row$se
  2 * pnorm(-abs(z))
}

# ── Safe OR extractor from pooled object ─────────────────────────────────────
mi_or_row <- function(pool_obj, term_name) {
  sm  <- as.data.frame(summary(pool_obj))
  sm$term <- rownames(sm)
  row <- sm[sm$term == term_name, ]
  if (nrow(row) != 1) stop("Term not found: ", term_name)
  list(
    OR  = exp(row$results),
    LCI = exp(row$`(lower`),
    UCI = exp(row$`upper)`),
    P   = mi_pval(pool_obj, term_name)
  )
}

