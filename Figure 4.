################################################################################
# STUDY: Multidimensional Circadian Misalignment and Depression
# ANALYSIS: Independent Nonlinear Associations + Interaction Visualization
# IMPROVEMENT: (1) P_interaction annotation on marginal plots
#              (2) 2D contour heatmap (Figure C) for joint effect
#              (3) Publication-quality 3-panel combined figure
################################################################################

rm(list = ls())
options(stringsAsFactors = FALSE)

# ==============================================================================
# 0. Load packages
# ==============================================================================

library(survey)
library(rms)
library(dplyr)
library(ggplot2)
library(patchwork)
library(car)
library(metR)

# ==============================================================================
# 1. Import dataset
# ==============================================================================

nhanes_data <- readRDS("D:/code/18.Dataset.rds")

# ==============================================================================
# 2. Variable preparation
# ==============================================================================

nhanes_data <- nhanes_data %>%
  mutate(
    RIAGENDR            = factor(RIAGENDR),
    RIDRETH1            = factor(RIDRETH1),
    DMDEDUC2            = factor(DMDEDUC2),
    smoke_status        = factor(smoke_status),
    DMDMARTZ            = factor(DMDMARTZ),
    AlcoholCategory     = factor(AlcoholCategory),
    diabetes_status     = factor(diabetes_status),
    hypertension_status = factor(hypertension_status),
    work_status         = factor(work_status)
  )

factor_vars <- c("RIAGENDR", "RIDRETH1", "DMDEDUC2", "smoke_status",
                 "DMDMARTZ", "AlcoholCategory",
                 "diabetes_status", "hypertension_status", "work_status")

# ==============================================================================
# 3. Survey design
# ==============================================================================

options(survey.lonely.psu = "adjust")

nhanes_design <- svydesign(
  id      = ~SDMVPSU,
  strata  = ~SDMVSTRA,
  weights = ~mec_adj,
  data    = nhanes_data,
  nest    = TRUE
)

dd <- datadist(nhanes_data)
options(datadist = "dd")

# ==============================================================================
# 4. Primary model: dual RCS (no interaction term)
# ==============================================================================

fit_joint <- svyglm(
  Moderate_depression_above ~
    rcs(CMB_Score, 3) +
    rcs(dur_wd, 3) +
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

cat("\n--- Primary model summary ---\n")
summary(fit_joint)

# ==============================================================================
# 5. Overall association tests (Wald)
# ==============================================================================

cat("\n--- Overall Association Tests (Wald) ---\n")
regTermTest(fit_joint, ~ rcs(CMB_Score, 3))
regTermTest(fit_joint, ~ rcs(dur_wd, 3))

# ==============================================================================
# 6. Nonlinearity tests (nested model comparison)
# ==============================================================================

cat("\n--- Nonlinearity Tests ---\n")

fit_cmb_linear <- svyglm(
  Moderate_depression_above ~
    CMB_Score +
    rcs(dur_wd, 3) +
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

fit_sleep_linear <- svyglm(
  Moderate_depression_above ~
    rcs(CMB_Score, 3) +
    dur_wd +
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

cat("\n  Nonlinearity test — CMB_Score:\n")
anova_cmb   <- anova(fit_cmb_linear,   fit_joint)
print(anova_cmb)

cat("\n  Nonlinearity test — dur_wd:\n")
anova_sleep <- anova(fit_sleep_linear, fit_joint)
print(anova_sleep)

# Extract p-values for nonlinearity (used in plot annotations)
p_nonlinear_cmb   <- anova_cmb$p
p_nonlinear_sleep <- anova_sleep$p

# ==============================================================================
# 7. Interaction model (for P_interaction annotation)
#    Product-term: CMB_Score x dur_wd (linear × linear)
#    This tests whether the joint effect exceeds additive expectation.
# ==============================================================================

cat("\n--- Interaction Test (CMB_Score × dur_wd) ---\n")

fit_interact <- svyglm(
  Moderate_depression_above ~
    rcs(CMB_Score, 3) +
    rcs(dur_wd, 3) +
    CMB_Score : dur_wd +            # linear product interaction term
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

# Wald test for the interaction term
interact_test <- regTermTest(fit_interact, ~ CMB_Score : dur_wd)
p_interaction <- interact_test$p
cat(sprintf("\n  P_interaction (CMB × sleep duration) = %.4f\n", p_interaction))

# Format for figure annotation
p_interact_label <- ifelse(
  p_interaction < 0.001,
  "P[interaction] < 0.001",
  sprintf("P[interaction] == %.3f", p_interaction)
)

p_nonlinear_cmb_label <- ifelse(
  p_nonlinear_cmb < 0.001,
  "P[nonlinear] < 0.001",
  sprintf("P[nonlinear] == %.3f", p_nonlinear_cmb)
)

p_nonlinear_sleep_label <- ifelse(
  p_nonlinear_sleep < 0.001,
  "P[nonlinear] < 0.001",
  sprintf("P[nonlinear] == %.3f", p_nonlinear_sleep)
)

# ==============================================================================
# 8. Marginal prediction — CMB_Score (Figure A)
# ==============================================================================

cmb_seq <- seq(
  quantile(nhanes_data$CMB_Score, 0.01, na.rm = TRUE),
  quantile(nhanes_data$CMB_Score, 0.99, na.rm = TRUE),
  length.out = 200
)

newdata_cmb <- data.frame(
  CMB_Score     = cmb_seq,
  dur_wd        = median(nhanes_data$dur_wd,        na.rm = TRUE),
  RIDAGEYR      = median(nhanes_data$RIDAGEYR,      na.rm = TRUE),
  BMI_value     = median(nhanes_data$BMI_value,     na.rm = TRUE),
  MET_total     = median(nhanes_data$MET_total,     na.rm = TRUE),
  INDFMPIR      = median(nhanes_data$INDFMPIR,      na.rm = TRUE),
  sedentary_min = median(nhanes_data$sedentary_min, na.rm = TRUE)
)

for (v in factor_vars) {
  newdata_cmb[[v]] <- factor(
    levels(nhanes_data[[v]])[1],
    levels = levels(nhanes_data[[v]])
  )
}

beta_joint <- coef(fit_joint)
Vcov_joint <- vcov(fit_joint)

Xmat_cmb  <- model.matrix(delete.response(terms(fit_joint)), data = newdata_cmb)
fit_cmb   <- as.vector(Xmat_cmb %*% beta_joint)
se_cmb    <- sqrt(diag(Xmat_cmb %*% Vcov_joint %*% t(Xmat_cmb)))

ref_cmb       <- median(nhanes_data$CMB_Score, na.rm = TRUE)
ref_idx_cmb   <- which.min(abs(newdata_cmb$CMB_Score - ref_cmb))
ref_logit_cmb <- fit_cmb[ref_idx_cmb]

newdata_cmb$OR <- exp(fit_cmb - ref_logit_cmb)
newdata_cmb$LL <- exp(fit_cmb - 1.96 * se_cmb - ref_logit_cmb)
newdata_cmb$UL <- exp(fit_cmb + 1.96 * se_cmb - ref_logit_cmb)

cmb_nadir <- newdata_cmb$CMB_Score[which.min(newdata_cmb$OR)]
cat(sprintf("\n  CMB nadir (min OR) = %.3f\n", cmb_nadir))

# ==============================================================================
# 9. Marginal prediction — dur_wd (Figure B)
# ==============================================================================

sleep_seq <- seq(
  quantile(nhanes_data$dur_wd, 0.01, na.rm = TRUE),
  quantile(nhanes_data$dur_wd, 0.99, na.rm = TRUE),
  length.out = 200
)

newdata_sleep <- data.frame(
  dur_wd        = sleep_seq,
  CMB_Score     = median(nhanes_data$CMB_Score,     na.rm = TRUE),
  RIDAGEYR      = median(nhanes_data$RIDAGEYR,      na.rm = TRUE),
  BMI_value     = median(nhanes_data$BMI_value,     na.rm = TRUE),
  MET_total     = median(nhanes_data$MET_total,     na.rm = TRUE),
  INDFMPIR      = median(nhanes_data$INDFMPIR,      na.rm = TRUE),
  sedentary_min = median(nhanes_data$sedentary_min, na.rm = TRUE)
)

for (v in factor_vars) {
  newdata_sleep[[v]] <- factor(
    levels(nhanes_data[[v]])[1],
    levels = levels(nhanes_data[[v]])
  )
}

Xmat_sleep    <- model.matrix(delete.response(terms(fit_joint)), data = newdata_sleep)
fit_sleep     <- as.vector(Xmat_sleep %*% beta_joint)
se_sleep      <- sqrt(diag(Xmat_sleep %*% Vcov_joint %*% t(Xmat_sleep)))

ref_sleep       <- median(nhanes_data$dur_wd, na.rm = TRUE)
ref_idx_sleep   <- which.min(abs(newdata_sleep$dur_wd - ref_sleep))
ref_logit_sleep <- fit_sleep[ref_idx_sleep]

newdata_sleep$OR <- exp(fit_sleep - ref_logit_sleep)
newdata_sleep$LL <- exp(fit_sleep - 1.96 * se_sleep - ref_logit_sleep)
newdata_sleep$UL <- exp(fit_sleep + 1.96 * se_sleep - ref_logit_sleep)

sleep_nadir <- newdata_sleep$dur_wd[which.min(newdata_sleep$OR)]
cat(sprintf("  Sleep duration nadir (min OR) = %.3f hours\n", sleep_nadir))

# ==============================================================================
# 10. Joint prediction grid — 2D contour heatmap (Figure C)
# ==============================================================================
#
# Grid spans the central 5th–95th percentile of each variable to avoid
# extreme leverage points distorting the colour scale.

cmb_grid   <- seq(
  quantile(nhanes_data$CMB_Score, 0.05, na.rm = TRUE),
  quantile(nhanes_data$CMB_Score, 0.95, na.rm = TRUE),
  length.out = 60
)

sleep_grid <- seq(
  quantile(nhanes_data$dur_wd, 0.05, na.rm = TRUE),
  quantile(nhanes_data$dur_wd, 0.95, na.rm = TRUE),
  length.out = 60
)

grid_df <- expand.grid(CMB_Score = cmb_grid, dur_wd = sleep_grid)

# Fix all other covariates at median / reference level
grid_df$RIDAGEYR      <- median(nhanes_data$RIDAGEYR,      na.rm = TRUE)
grid_df$BMI_value     <- median(nhanes_data$BMI_value,     na.rm = TRUE)
grid_df$MET_total     <- median(nhanes_data$MET_total,     na.rm = TRUE)
grid_df$INDFMPIR      <- median(nhanes_data$INDFMPIR,      na.rm = TRUE)
grid_df$sedentary_min <- median(nhanes_data$sedentary_min, na.rm = TRUE)

for (v in factor_vars) {
  grid_df[[v]] <- factor(
    levels(nhanes_data[[v]])[1],
    levels = levels(nhanes_data[[v]])
  )
}

# Compute predicted log-odds on full grid
Xmat_grid  <- model.matrix(delete.response(terms(fit_joint)), data = grid_df)
fit_grid   <- as.vector(Xmat_grid %*% beta_joint)

# Reference: median of both variables simultaneously
ref_grid_row <- which(
  abs(grid_df$CMB_Score - median(nhanes_data$CMB_Score, na.rm = TRUE)) ==
    min(abs(grid_df$CMB_Score - median(nhanes_data$CMB_Score, na.rm = TRUE))) &
    abs(grid_df$dur_wd - median(nhanes_data$dur_wd, na.rm = TRUE)) ==
    min(abs(grid_df$dur_wd - median(nhanes_data$dur_wd, na.rm = TRUE)))
)

# Fallback: use the closest single point if exact match fails
if (length(ref_grid_row) == 0 || length(ref_grid_row) > 1) {
  dist_mat     <- abs(grid_df$CMB_Score - median(nhanes_data$CMB_Score, na.rm = TRUE)) +
    abs(grid_df$dur_wd    - median(nhanes_data$dur_wd,    na.rm = TRUE))
  ref_grid_row <- which.min(dist_mat)
}

ref_logit_grid <- fit_grid[ref_grid_row[1]]
grid_df$log_OR <- fit_grid - ref_logit_grid
grid_df$OR     <- exp(grid_df$log_OR)

# Symmetric log_OR colour limits for diverging palette
max_abs <- quantile(abs(grid_df$log_OR), 0.97)
clim    <- c(-max_abs, max_abs)

