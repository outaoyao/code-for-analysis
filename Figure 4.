# ==============================================================================
# 13. Build Figure C — 3 contour lines only: OR=1.00, 1.20, 1.50
#     (OR minimum in grid = 0.98, so no sub-1.0 contour exists)
# ==============================================================================

x_lo <- quantile(nhanes_data$CMB_Score, 0.05, na.rm = TRUE)
x_hi <- quantile(nhanes_data$CMB_Score, 0.95, na.rm = TRUE)
y_lo <- quantile(nhanes_data$dur_wd,    0.05, na.rm = TRUE)
y_hi <- quantile(nhanes_data$dur_wd,    0.95, na.rm = TRUE)

p_interact_plain <- ifelse(
  p_interaction < 0.001,
  "P-interaction < 0.001",
  sprintf("P-interaction = %.3f", p_interaction)
)

# ── Contour specification: 3 lines, all within [0.98, 4.68] ──────────────────
#   OR=1.00  white  dashed  — reference boundary (just inside the data range)
#   OR=1.20  gold   solid   — modest elevation, CUD-safe on orange background
#   OR=1.50  magenta solid  — strong elevation, distinguishable by deuteranopes
#
# Verify before use:
cat(sprintf("  Grid OR range: [%.4f, %.4f]\n",
            min(grid_df$OR), max(grid_df$OR)))
cat("  Contour breaks 1.00 / 1.20 / 1.50 — all within range: ")
cat(all(c(1.00, 1.20, 1.50) >= min(grid_df$OR) &
          c(1.00, 1.20, 1.50) <= max(grid_df$OR)), "\n")

contour_breaks  <- c(1.00,     1.20,     1.50)
contour_colours <- c("#FFFFFF", "#FFD700", "#CC0099")
contour_ltypes  <- c("dashed",  "solid",   "solid")
contour_lwd     <- c(1.1,       1.0,       1.0)
contour_labels  <- c("OR=1.00", "OR=1.20", "OR=1.50")
label_colours   <- c("grey15",  "#C8A800", "#CC0099")

# ── OR label positions ────────────────────────────────────────────────────────
find_label_pos <- function(target_or, grid, x_frac = 0.5, y_nudge = 0.12) {
  x_range  <- range(grid$CMB_Score)
  x_target <- x_range[1] + x_frac * diff(x_range)
  x_vals   <- unique(grid$CMB_Score)
  x_use    <- x_vals[which.min(abs(x_vals - x_target))]
  sub      <- grid[abs(grid$CMB_Score - x_use) < 1e-6, ]
  idx      <- which.min(abs(sub$OR - target_or))
  list(x = sub$CMB_Score[idx],
       y = sub$dur_wd[idx] + y_nudge)
}

lab_10 <- find_label_pos(1.00, grid_df, x_frac = 0.45, y_nudge =  0.18)
lab_12 <- find_label_pos(1.20, grid_df, x_frac = 0.65, y_nudge =  0.22)
lab_15 <- find_label_pos(1.50, grid_df, x_frac = 0.80, y_nudge =  0.28)

# ── Build p_C ─────────────────────────────────────────────────────────────────
p_C <- ggplot(grid_df, aes(x = CMB_Score, y = dur_wd)) +
  
  # Heatmap tiles
  geom_tile(aes(fill = log_OR)) +
  
  # 3 contour lines — colour + linetype double encoding
  geom_contour(aes(z = OR), breaks = 1.00,
               color = contour_colours[1], linetype = contour_ltypes[1],
               linewidth = contour_lwd[1]) +
  geom_contour(aes(z = OR), breaks = 1.20,
               color = contour_colours[2], linetype = contour_ltypes[2],
               linewidth = contour_lwd[2]) +
  geom_contour(aes(z = OR), breaks = 1.50,
               color = contour_colours[3], linetype = contour_ltypes[3],
               linewidth = contour_lwd[3]) +
  
  # OR text labels — colour-matched, placed near but not on the lines
  annotate("text", x = lab_10$x, y = lab_10$y, label = "OR=1.00",
           color = label_colours[1], size = 2.8, fontface = "bold",
           hjust = 0.5) +
  annotate("text", x = lab_12$x, y = lab_12$y, label = "OR=1.20",
           color = label_colours[2], size = 2.8, fontface = "bold",
           hjust = 0.5) +
  annotate("text", x = lab_15$x, y = lab_15$y, label = "OR=1.50",
           color = label_colours[3], size = 2.8, fontface = "bold",
           hjust = 0.5) +
  
  # Reference cross-hair at joint median
  geom_vline(xintercept = median(nhanes_data$CMB_Score, na.rm = TRUE),
             linetype = "dashed", color = "white",
             linewidth = 0.75, alpha = 0.85) +
  geom_hline(yintercept = median(nhanes_data$dur_wd, na.rm = TRUE),
             linetype = "dashed", color = "white",
             linewidth = 0.75, alpha = 0.85) +
  
  # Reference point dot
  annotate("point",
           x = median(nhanes_data$CMB_Score, na.rm = TRUE),
           y = median(nhanes_data$dur_wd,    na.rm = TRUE),
           size = 2.8, shape = 21, fill = "white", color = "black") +
  
  # Manual legend (top-left) — 3 rows only
  annotate("segment",
           x    = x_lo + 0.03 * (x_hi - x_lo),
           xend = x_lo + 0.13 * (x_hi - x_lo),
           y    = y_hi - (0.07 * (y_hi - y_lo)) * (1:3),
           yend = y_hi - (0.07 * (y_hi - y_lo)) * (1:3),
           color    = contour_colours,
           linetype = contour_ltypes,
           linewidth = 0.9) +
  annotate("text",
           x        = x_lo + 0.15 * (x_hi - x_lo),
           y        = y_hi - (0.07 * (y_hi - y_lo)) * (1:3),
           label    = contour_labels,
           color    = label_colours,
           size     = 2.5, hjust = 0, fontface = "bold") +
  
  # CUD-safe diverging fill scale
  scale_fill_gradientn(
    colours = c("#053061", "#2166AC", "#92C5DE",
                "#F7F7F7",
                "#F1A340", "#E08214", "#7F3B08"),
    limits  = clim,
    name    = "log(OR)\nvs. median",
    guide   = guide_colorbar(
      barheight = unit(5, "cm"), barwidth = unit(0.5, "cm"),
      title.hjust = 0.5)
  ) +
  
  coord_cartesian(xlim = c(x_lo, x_hi),
                  ylim = c(y_lo, y_hi),
                  clip = "on") +
  
  theme_classic(base_size = 13) +
  theme(
    plot.title    = element_text(face = "bold",   size = 12),
    plot.subtitle = element_text(face = "italic", size = 11,
                                 color = "black",
                                 hjust = 0.9,
                                 margin = margin(t = 2, b = 6)),
    axis.title    = element_text(size = 11),
    legend.title  = element_text(size = 10, hjust = 0.5),
    legend.text   = element_text(size = 9),
    legend.position = "right",
    plot.margin   = margin(8, 12, 8, 8)
  ) +
  labs(
    x        = "Circadian Misalignment",
    y        = "Weekday Sleep Duration (hours)",
    title    = "c",
    subtitle = p_interact_plain
  )

cat(sprintf("p_C built: %s\n", class(p_C)[1]))

