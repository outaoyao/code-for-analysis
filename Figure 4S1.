################################################################################
# STUDY: Multidimensional Circadian Misalignment and Depression
# ANALYSIS: Independent Nonlinear Associations + Interaction Visualization
# EXPOSURE: CMB_Score + Weekend Sleep Duration (dur_we)
# COLOUR:   Panel b — pink/mauve (#CC79A7), CUD-safe
################################################################################

rm(list = ls())
options(stringsAsFactors = FALSE)

library(survey)
library(rms)
library(dplyr)
library(ggplot2)
library(patchwork)
library(car)
library(metR)

# ==============================================================================
# 1. Import dataset
# ==============================================================================

nhanes_data <- readRDS("D:/code/18.Dataset.rds")

# ==============================================================================
# 2. Variable preparation
# ==============================================================================

nhanes_data <- nhanes_data %>%
  mutate(
    RIAGENDR            = factor(RIAGENDR),
    RIDRETH1            = factor(RIDRETH1),
    DMDEDUC2            = factor(DMDEDUC2),
    smoke_status        = factor(smoke_status),
    DMDMARTZ            = factor(DMDMARTZ),
    AlcoholCategory     = factor(AlcoholCategory),
    diabetes_status     = factor(diabetes_status),
    hypertension_status = factor(hypertension_status),
    work_status         = factor(work_status)
  )

factor_vars <- c("RIAGENDR", "RIDRETH1", "DMDEDUC2", "smoke_status",
                 "DMDMARTZ", "AlcoholCategory",
                 "diabetes_status", "hypertension_status", "work_status")

# ==============================================================================
# 3. Survey design
# ==============================================================================

options(survey.lonely.psu = "adjust")

nhanes_design <- svydesign(
  id      = ~SDMVPSU,
  strata  = ~SDMVSTRA,
  weights = ~mec_adj,
  data    = nhanes_data,
  nest    = TRUE
)

dd <- datadist(nhanes_data)
options(datadist = "dd")

# ==============================================================================
# 4. Primary model: CMB_Score + dur_we (weekend sleep duration)
# ==============================================================================

fit_joint <- svyglm(
  Moderate_depression_above ~
    rcs(CMB_Score, 3) +
    rcs(dur_we, 3) +           # weekend sleep duration
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

cat("\n--- Primary model summary ---\n")
summary(fit_joint)

# ==============================================================================
# 5. Overall association tests (Wald)
# ==============================================================================

cat("\n--- Overall Association Tests (Wald) ---\n")
regTermTest(fit_joint, ~ rcs(CMB_Score, 3))
regTermTest(fit_joint, ~ rcs(dur_we, 3))

# ==============================================================================
# 6. Nonlinearity tests
# ==============================================================================

cat("\n--- Nonlinearity Tests ---\n")

fit_cmb_linear <- svyglm(
  Moderate_depression_above ~
    CMB_Score +
    rcs(dur_we, 3) +
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

fit_sleep_linear <- svyglm(
  Moderate_depression_above ~
    rcs(CMB_Score, 3) +
    dur_we +                   # weekend sleep duration (linear)
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

cat("\n  Nonlinearity test — CMB_Score:\n")
anova_cmb   <- anova(fit_cmb_linear,  fit_joint)
print(anova_cmb)

cat("\n  Nonlinearity test — dur_we:\n")
anova_sleep <- anova(fit_sleep_linear, fit_joint)
print(anova_sleep)

p_nonlinear_cmb   <- anova_cmb$p
p_nonlinear_sleep <- anova_sleep$p

# ==============================================================================
# 7. Interaction test (CMB_Score × dur_we)
# ==============================================================================

cat("\n--- Interaction Test (CMB_Score × dur_we) ---\n")

fit_interact <- svyglm(
  Moderate_depression_above ~
    rcs(CMB_Score, 3) +
    rcs(dur_we, 3) +
    CMB_Score : dur_we +
    RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 +
    smoke_status + DMDMARTZ + BMI_value + AlcoholCategory +
    diabetes_status + hypertension_status + work_status +
    MET_total + INDFMPIR + sedentary_min,
  design = nhanes_design,
  family = quasibinomial()
)

interact_test <- regTermTest(fit_interact, ~ CMB_Score : dur_we)
p_interaction <- interact_test$p
cat(sprintf("\n  P_interaction (CMB × weekend sleep) = %.4f\n", p_interaction))

p_nonlinear_cmb_label <- ifelse(
  p_nonlinear_cmb < 0.001,
  "P-nonlinear < 0.001",
  sprintf("P-nonlinear = %.3f", p_nonlinear_cmb)
)

p_nonlinear_sleep_label <- ifelse(
  p_nonlinear_sleep < 0.001,
  "P-nonlinear < 0.001",
  sprintf("P-nonlinear = %.3f", p_nonlinear_sleep)
)

p_interact_plain <- ifelse(
  p_interaction < 0.001,
  "P-interaction < 0.001",
  sprintf("P-interaction = %.3f", p_interaction)
)

# ==============================================================================
# 8. Marginal prediction — CMB_Score (Panel a)
# ==============================================================================

cmb_seq <- seq(
  quantile(nhanes_data$CMB_Score, 0.01, na.rm = TRUE),
  quantile(nhanes_data$CMB_Score, 0.99, na.rm = TRUE),
  length.out = 200
)

newdata_cmb <- data.frame(
  CMB_Score     = cmb_seq,
  dur_we        = median(nhanes_data$dur_we,        na.rm = TRUE),
  RIDAGEYR      = median(nhanes_data$RIDAGEYR,      na.rm = TRUE),
  BMI_value     = median(nhanes_data$BMI_value,     na.rm = TRUE),
  MET_total     = median(nhanes_data$MET_total,     na.rm = TRUE),
  INDFMPIR      = median(nhanes_data$INDFMPIR,      na.rm = TRUE),
  sedentary_min = median(nhanes_data$sedentary_min, na.rm = TRUE)
)

for (v in factor_vars) {
  newdata_cmb[[v]] <- factor(levels(nhanes_data[[v]])[1],
                             levels = levels(nhanes_data[[v]]))
}

beta_joint <- coef(fit_joint)
Vcov_joint <- vcov(fit_joint)

Xmat_cmb      <- model.matrix(delete.response(terms(fit_joint)), data = newdata_cmb)
fit_cmb_pred  <- as.vector(Xmat_cmb %*% beta_joint)
se_cmb        <- sqrt(diag(Xmat_cmb %*% Vcov_joint %*% t(Xmat_cmb)))

ref_cmb       <- median(nhanes_data$CMB_Score, na.rm = TRUE)
ref_idx_cmb   <- which.min(abs(newdata_cmb$CMB_Score - ref_cmb))
ref_logit_cmb <- fit_cmb_pred[ref_idx_cmb]

newdata_cmb$OR <- exp(fit_cmb_pred - ref_logit_cmb)
newdata_cmb$LL <- exp(fit_cmb_pred - 1.96 * se_cmb - ref_logit_cmb)
newdata_cmb$UL <- exp(fit_cmb_pred + 1.96 * se_cmb - ref_logit_cmb)

cmb_nadir <- newdata_cmb$CMB_Score[which.min(newdata_cmb$OR)]
cat(sprintf("\n  CMB nadir (min OR) = %.3f\n", cmb_nadir))

# ==============================================================================
# 9. Marginal prediction — dur_we (Panel b)
# ==============================================================================

sleep_seq <- seq(
  quantile(nhanes_data$dur_we, 0.01, na.rm = TRUE),
  quantile(nhanes_data$dur_we, 0.99, na.rm = TRUE),
  length.out = 200
)

newdata_sleep <- data.frame(
  dur_we        = sleep_seq,
  CMB_Score     = median(nhanes_data$CMB_Score,     na.rm = TRUE),
  RIDAGEYR      = median(nhanes_data$RIDAGEYR,      na.rm = TRUE),
  BMI_value     = median(nhanes_data$BMI_value,     na.rm = TRUE),
  MET_total     = median(nhanes_data$MET_total,     na.rm = TRUE),
  INDFMPIR      = median(nhanes_data$INDFMPIR,      na.rm = TRUE),
  sedentary_min = median(nhanes_data$sedentary_min, na.rm = TRUE)
)

for (v in factor_vars) {
  newdata_sleep[[v]] <- factor(levels(nhanes_data[[v]])[1],
                               levels = levels(nhanes_data[[v]]))
}

Xmat_sleep      <- model.matrix(delete.response(terms(fit_joint)), data = newdata_sleep)
fit_sleep_pred  <- as.vector(Xmat_sleep %*% beta_joint)
se_sleep        <- sqrt(diag(Xmat_sleep %*% Vcov_joint %*% t(Xmat_sleep)))

ref_sleep       <- median(nhanes_data$dur_we, na.rm = TRUE)
ref_idx_sleep   <- which.min(abs(newdata_sleep$dur_we - ref_sleep))
ref_logit_sleep <- fit_sleep_pred[ref_idx_sleep]

newdata_sleep$OR <- exp(fit_sleep_pred - ref_logit_sleep)
newdata_sleep$LL <- exp(fit_sleep_pred - 1.96 * se_sleep - ref_logit_sleep)
newdata_sleep$UL <- exp(fit_sleep_pred + 1.96 * se_sleep - ref_logit_sleep)

sleep_nadir <- newdata_sleep$dur_we[which.min(newdata_sleep$OR)]
cat(sprintf("  Weekend sleep nadir (min OR) = %.3f hours\n", sleep_nadir))

# ==============================================================================
# 10. Joint prediction grid for heatmap (Panel c)
# ==============================================================================

cmb_grid   <- seq(quantile(nhanes_data$CMB_Score, 0.05, na.rm = TRUE),
                  quantile(nhanes_data$CMB_Score, 0.95, na.rm = TRUE),
                  length.out = 60)

sleep_grid <- seq(quantile(nhanes_data$dur_we, 0.05, na.rm = TRUE),
                  quantile(nhanes_data$dur_we, 0.95, na.rm = TRUE),
                  length.out = 60)

grid_df <- expand.grid(CMB_Score = cmb_grid, dur_we = sleep_grid)

grid_df$RIDAGEYR      <- median(nhanes_data$RIDAGEYR,      na.rm = TRUE)
grid_df$BMI_value     <- median(nhanes_data$BMI_value,     na.rm = TRUE)
grid_df$MET_total     <- median(nhanes_data$MET_total,     na.rm = TRUE)
grid_df$INDFMPIR      <- median(nhanes_data$INDFMPIR,      na.rm = TRUE)
grid_df$sedentary_min <- median(nhanes_data$sedentary_min, na.rm = TRUE)

for (v in factor_vars) {
  grid_df[[v]] <- factor(levels(nhanes_data[[v]])[1],
                         levels = levels(nhanes_data[[v]]))
}

Xmat_grid <- model.matrix(delete.response(terms(fit_joint)), data = grid_df)
fit_grid  <- as.vector(Xmat_grid %*% beta_joint)

dist_mat     <- abs(grid_df$CMB_Score - median(nhanes_data$CMB_Score, na.rm = TRUE)) +
  abs(grid_df$dur_we    - median(nhanes_data$dur_we,    na.rm = TRUE))
ref_grid_row <- which.min(dist_mat)

ref_logit_grid <- fit_grid[ref_grid_row]
grid_df$log_OR <- fit_grid - ref_logit_grid
grid_df$OR     <- exp(grid_df$log_OR)

max_abs <- quantile(abs(grid_df$log_OR), 0.97)
clim    <- c(-max_abs, max_abs)

cat(sprintf("  Grid OR range: [%.4f, %.4f]\n", min(grid_df$OR), max(grid_df$OR)))

