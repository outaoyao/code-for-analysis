hour_to_hhmm <- function(x) {
  if (is.na(x)) return(NA_character_)
  
  h <- floor(x)
  m <- round((x - h) * 60)
  
  if (m == 60) {
    h <- h + 1
    m <- 0
  }
  
  h <- h %% 24
  sprintf("%02d:%02d", h, m)
}

circular_diff <- function(x, y, period = 24) {
  raw_diff <- abs(x - y)
  pmin(raw_diff, period - raw_diff)
}

score_timing <- function(x, ref_low, ref_high) {
  if (is.na(x)) return(NA_integer_)
  
  if (ref_low <= ref_high) {
    in_interval <- (x >= ref_low & x <= ref_high)
    if (in_interval) return(0L)
    
    d1 <- circular_diff(x, ref_low)
    d2 <- circular_diff(x, ref_high)
    dist_to_interval <- min(d1, d2)
    
  } else {
    # Wrap-around interval retained for robustness
    in_interval <- (x >= ref_low & x < 24) | (x >= 0 & x <= ref_high)
    if (in_interval) return(0L)
    
    d1 <- circular_diff(x, ref_low)
    d2 <- circular_diff(x, ref_high)
    dist_to_interval <- min(d1, d2)
  }
  
  if (dist_to_interval <= 1) {
    return(1L)
  } else if (dist_to_interval <= 2) {
    return(2L)
  } else {
    return(3L)
  }
}

get_ref <- function(ref_tbl, metric_name_input) {
  row <- ref_tbl %>% filter(metric_name == metric_name_input)
  
  if (nrow(row) != 1) {
    stop("Reference interval lookup failed for: ", metric_name_input)
  }
  
  list(low = row$ref_low[[1]], high = row$ref_high[[1]])
}

group_total_score <- function(x) {
  case_when(
    x >= 0  & x <= 3  ~ "0-3",
    x >= 4  & x <= 6  ~ "4-6",
    x >= 7  & x <= 9  ~ "7-9",
    x >= 10 & x <= 12 ~ "10-12",
    x >= 13           ~ "13+",
    TRUE              ~ NA_character_
  )
}

apply_sleep_timing_scores <- function(dat, ref_tbl) {
  
  ref_onset_wd <- get_ref(ref_tbl, "sleep_onset_weekday")
  ref_onset_we <- get_ref(ref_tbl, "sleep_onset_weekend")
  ref_wake_wd  <- get_ref(ref_tbl, "wake_time_weekday")
  ref_wake_we  <- get_ref(ref_tbl, "wake_time_weekend")
  ref_mid_wd   <- get_ref(ref_tbl, "sleep_midpoint_weekday")
  ref_mid_we   <- get_ref(ref_tbl, "sleep_midpoint_weekend")
  
  dat %>%
    mutate(
      score_sleep_onset_weekday = vapply(
        sleep_onset_weekday_hours, score_timing, integer(1),
        ref_low = ref_onset_wd$low, ref_high = ref_onset_wd$high
      ),
      score_sleep_onset_weekend = vapply(
        sleep_onset_weekend_hours, score_timing, integer(1),
        ref_low = ref_onset_we$low, ref_high = ref_onset_we$high
      ),
      score_wake_time_weekday = vapply(
        wake_time_weekday_hours, score_timing, integer(1),
        ref_low = ref_wake_wd$low, ref_high = ref_wake_wd$high
      ),
      score_wake_time_weekend = vapply(
        wake_time_weekend_hours, score_timing, integer(1),
        ref_low = ref_wake_we$low, ref_high = ref_wake_we$high
      ),
      score_midpoint_weekday = vapply(
        sleep_midpoint_weekday_hours, score_timing, integer(1),
        ref_low = ref_mid_wd$low, ref_high = ref_mid_wd$high
      ),
      score_midpoint_weekend = vapply(
        sleep_midpoint_weekend_hours, score_timing, integer(1),
        ref_low = ref_mid_we$low, ref_high = ref_mid_we$high
      ),
      sleep_timing_total_score =
        score_sleep_onset_weekday +
        score_sleep_onset_weekend +
        score_wake_time_weekday +
        score_wake_time_weekend +
        score_midpoint_weekday +
        score_midpoint_weekend,
      sleep_timing_total_group = factor(
        group_total_score(sleep_timing_total_score),
        levels = c("0-3", "4-6", "7-9", "10-12", "13+")
      )
    )
}

