#
# Scoring logic:
#   Score 0: within reference interval                   [ref_lo,       ref_hi      ]
#   Score 1: ref interval ± 1 h  (includes Score 0)     [ref_lo - 1,   ref_hi + 1  ]
#   Score 2: ref interval ± 2 h  (includes Score 1)     [ref_lo - 2,   ref_hi + 2  ]
#   Score 3: ref interval ± 3 h  (includes Score 2)     [ref_lo - 3,   ref_hi + 3  ]
#
# Intervals that cross midnight are displayed as two segments:
#   "hh:mm–23:59 / 00:00–hh:mm"
#
# Add this block at the END of Script 1, after sink() is called.
# Dependencies: flextable, officer, dplyr
# Output:
#   D:/code/table/Sensitivity_Table_S1_SleepTimingScores.docx
#   D:/code/table/Sensitivity_Table_S1_SleepTimingScores.html
# ==============================================================================

library(flextable)
