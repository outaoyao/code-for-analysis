library(dplyr)

# ------------------------------------------------------------------------------
# 1. Helper functions
# ------------------------------------------------------------------------------

# Convert decimal hours to "hh:mm" on a 24-h clock
h2hm <- function(x) {
  x <- ((x %% 24) + 24) %% 24
  h <- floor(x)
  m <- round((x - h) * 60)
  if (!is.na(m) && m == 60) { h <- (h + 1L) %% 24L; m <- 0L }
  sprintf("%02d:%02d", h, m)
}

# Cumulative interval label for score s:
#   full range = [ref_lo - s,  ref_hi + s]
#   wraps midnight → "lo–23:59 / 00:00–hi"
#   no wrap       → "lo–hi"
cum_interval <- function(ref_lo, ref_hi, s) {
  lo <- ref_lo - s
  hi <- ref_hi + s
  if (lo < 0 || hi >= 24) {
    paste0(h2hm(lo), "\u201323:59 / 00:00\u2013", h2hm(hi))
  } else {
    paste0(h2hm(lo), "\u2013", h2hm(hi))
  }
}

nadir_hm <- function(ref_lo, ref_hi) h2hm((ref_lo + ref_hi) / 2)

make_row <- function(metric, daytype, ref_lo, ref_hi) {
  data.frame(
    metric  = metric,
    daytype = daytype,
    s0      = cum_interval(ref_lo, ref_hi, 0),
    s1      = cum_interval(ref_lo, ref_hi, 1),
    s2      = cum_interval(ref_lo, ref_hi, 2),
    s3      = cum_interval(ref_lo, ref_hi, 3),
    nadir   = nadir_hm(ref_lo, ref_hi),
    stringsAsFactors = FALSE
  )
}

