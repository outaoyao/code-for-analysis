extract_and_validate_data <- function(rcs_object, time_type_name) {
  data_df <- rcs_object[["newdat"]]
  if (!is.data.frame(data_df)) data_df <- as.data.frame(data_df)
  
  numeric_cols <- c("yhat", "lower", "upper")
