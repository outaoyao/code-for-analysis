# 8. Association Gradient Zonation & Lowest-Association Interval Analysis -----------------------------

calculate_nadir_adjacent_interval <- function(rcs_data, data_name) {
  min_or <- min(rcs_data$yhat, na.rm = TRUE)
  threshold <- 1.05 * min_or
  below_threshold <- which(rcs_data$yhat <= threshold)
  best_int <- range(rcs_data$hours[below_threshold])
  
  cat(sprintf("\n--- %s Timing Interval with Minimal Estimated Association (Model 4) ---\n", data_name))
  cat(sprintf("Nadir OR: %.4f | nadir_adjacent_interval: %.2f - %.2f h\n", min_or, best_int[1], best_int[2]))
  
  return(list(nadir_adjacent_interval = best_int, min_or = min_or))
}

