# Function to map exposure based on RELATIVE deviation from Nadir
map_or_to_score <- function(hours_val, rcs_plot_data) {
  # 1. Identify predicted OR
  idx <- which.min(abs(rcs_plot_data$hours - hours_val))
  predicted_or <- rcs_plot_data$yhat[idx]
  nadir_or     <- min(rcs_plot_data$yhat)
  
  # 2. Scoring based on RELATIVE GRADIENT (Symmetry Protection)
  # All thresholds are now multipliers of the specific model's nadir
  score <- case_when(
    predicted_or <= (VAL_REF * nadir_or)      ~ 0, # Nadir zone (0-5% deviation)
    predicted_or <= (VAL_MILD * nadir_or)     ~ 1, # Mild gradient (5-20% deviation)
    predicted_or <= (VAL_MODERATE * nadir_or) ~ 2, # Moderate gradient (20-50% deviation)
    TRUE                                      ~ 3  # High gradient (>50% deviation)
  )
  return(score)
}

# --- FINAL SUMMARY FOR MANUSCRIPT ---
cat("\n=== TABLE: RCS-DERIVED EXPOSURE INTERVALS BY ASSOCIATION SCORE ===\n")

summarize_onset_intervals <- function(rcs_data, label) {
  # 1. Identify Nadir
  nadir_info <- rcs_data[which.min(rcs_data$yhat), ]
  
  cat(sprintf("\nTiming Type: %s\n", label))
  cat(sprintf("Optimal Nadir: %.2f hours past midnight (Lowest OR: %.4f)\n", 
              nadir_info$hours, nadir_info$yhat))
  
  # 2. Map every point in the spline to a score
  rcs_data$score <- sapply(rcs_data$hours, map_or_to_score, rcs_plot_data = rcs_data)
  
  # 3. Aggregate intervals per score
  summary_tab <- rcs_data %>%
    group_by(score) %>%
    summarise(
      Start_Hour = min(hours),
      End_Hour   = max(hours),
      .groups = 'drop'
    ) %>%
    mutate(Clinical_Interpretation = c("Reference (Optimal)", "Mild Risk Elevation", 
                                       "Moderate Risk Elevation", "High Risk Elevation")[score + 1])
  
  print(as.data.frame(summary_tab))
}

