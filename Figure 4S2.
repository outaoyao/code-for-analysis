find_label_pos_pub <- function(target_or, grid, x_var, y_var, x_frac = 0.5, y_nudge = 0.12) {
  x_range  <- range(grid[[x_var]], na.rm = TRUE)
  x_target <- x_range[1] + x_frac * diff(x_range)
  x_vals   <- unique(grid[[x_var]])
  x_use    <- x_vals[which.min(abs(x_vals - x_target))]
  sub      <- grid[abs(grid[[x_var]] - x_use) < 1e-6, ]
  idx      <- which.min(abs(sub$OR - target_or))
  list(
    x = sub[[x_var]][idx],
    y = sub[[y_var]][idx] + y_nudge
  )
}

