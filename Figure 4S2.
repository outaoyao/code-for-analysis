make_formula_joint <- function(include_x1_nonlin = TRUE,
                               include_x2_nonlin = TRUE,
                               include_interaction = FALSE) {
  
  x1_terms <- if (include_x1_nonlin) {
    c("x1_lin", "x1_nonlin1")
  } else {
    c("x1_lin")
  }
  
  x2_terms <- if (include_x2_nonlin) {
    c("x2_lin", "x2_nonlin1")
  } else {
    c("x2_lin")
  }
  
  rhs_terms <- c(x1_terms, x2_terms)
  
  if (include_interaction) {
    rhs_terms <- c(rhs_terms, "x1_lin:x2_lin")
  }
  
  rhs_terms <- c(rhs_terms, adj_covs)
  
  as.formula(paste(OUTCOME_VAR, "~", paste(rhs_terms, collapse = " + ")))
}

