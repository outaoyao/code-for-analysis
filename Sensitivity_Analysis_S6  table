################################################################################
# SCRIPT: Robust Bootstrap Stability Assessment (Fixed Version)
# PURPOSE: Estimate 95% CI for the 8.69 risk threshold and curve nadir.
################################################################################

library(survey)
library(rms)
library(dplyr)

# 1. Environment Setup ---------------------------------------------------------
# Ensure nhanes_final is the dataset after merging raw weights
# Using Model 4 variables for prediction
set.seed(2026)
n_iterations <- 1000 
boot_results <- data.frame(nadir = numeric(n_iterations), 
                           risk_point_1.1 = numeric(n_iterations))

# 2. Define Reference Values for Prediction ------------------------------------
# We pre-calculate these to ensure consistency across all bootstrap runs
ref_age  <- mean(nhanes_final$RIDAGEYR, na.rm=TRUE)
ref_bmi  <- mean(nhanes_final$BMI_value, na.rm=TRUE)
ref_met  <- mean(nhanes_final$MET_total, na.rm=TRUE)
ref_pir  <- mean(nhanes_final$INDFMPIR, na.rm=TRUE)
ref_sed  <- mean(nhanes_final$sedentary_min, na.rm=TRUE)

# 3. Execution Loop ------------------------------------------------------------
cat("Starting 1,000 Bootstrap iterations with robust error handling...\n")

for(i in 1:n_iterations) {
  
  # 3.1 Robust Resampling
  # We ensure the resampled data has at least some cases of the outcome
  boot_idx <- sample(1:nrow(nhanes_final), replace = TRUE)
  boot_df  <- nhanes_final[boot_idx, ]
  
  # 3.2 Survey Design
  boot_design <- svydesign(id = ~SDMVPSU, strata = ~SDMVSTRA, 
                           weights = ~mec_adj, data = boot_df, nest = TRUE)
  
  # 3.3 Model Fitting with Error Handling
  # We use try() to catch the 'eta' error and skip invalid iterations
  boot_fit <- try({
    svyglm(Moderate_depression_above ~ rcs(CMB_Score, 4) + 
             RIDAGEYR + RIAGENDR + RIDRETH1 + DMDEDUC2 + smoke_status + 
             DMDMARTZ + BMI_value + AlcoholCategory + diabetes_status + 
             hypertension_status + work_status + MET_total + INDFMPIR + 
             sedentary_min,
           design = boot_design, family = quasibinomial())
  }, silent = TRUE)
  
  # Skip to next iteration if model failed to converge
  if (inherits(boot_fit, "try-error") || is.null(boot_fit)) {
    next
  }
  
  # 3.4 Predict Thresholds
  pred_grid <- data.frame(CMB_Score = seq(0, 18, length.out = 500))
  
  pred_grid$RIDAGEYR <- ref_age
  pred_grid$BMI_value <- ref_bmi
  pred_grid$MET_total <- ref_met
  pred_grid$INDFMPIR  <- ref_pir
  pred_grid$sedentary_min <- ref_sed
  
  pred_grid$RIAGENDR     <- factor(levels(nhanes_final$RIAGENDR)[1], levels = levels(nhanes_final$RIAGENDR))
  pred_grid$RIDRETH1     <- factor(levels(nhanes_final$RIDRETH1)[1], levels = levels(nhanes_final$RIDRETH1))
  pred_grid$DMDEDUC2     <- factor(levels(nhanes_final$DMDEDUC2)[1], levels = levels(nhanes_final$DMDEDUC2))
  pred_grid$smoke_status <- factor(levels(nhanes_final$smoke_status)[1], levels = levels(nhanes_final$smoke_status))
  pred_grid$DMDMARTZ     <- factor(levels(nhanes_final$DMDMARTZ)[1], levels = levels(nhanes_final$DMDMARTZ))
  pred_grid$AlcoholCategory <- factor(levels(nhanes_final$AlcoholCategory)[1], levels = levels(nhanes_final$AlcoholCategory))
  pred_grid$diabetes_status <- factor(levels(nhanes_final$diabetes_status)[1], levels = levels(nhanes_final$diabetes_status))
  pred_grid$hypertension_status <- factor(levels(nhanes_final$hypertension_status)[1], levels = levels(nhanes_final$hypertension_status))
  pred_grid$work_status  <- factor(levels(nhanes_final$work_status)[1], levels = levels(nhanes_final$work_status))
  
  # Safe Prediction
  preds <- try(predict(boot_fit, newdata = pred_grid, type = "link"), silent = TRUE)
  if (inherits(preds, "try-error")) next
  
  # 3.5 Metrics Extraction
  # Nadir
  nadir_idx <- which.min(as.numeric(preds))
  nadir_val <- pred_grid$CMB_Score[nadir_idx]
  
  # Risk escalation (OR >= 1.10)
  target_link <- preds[nadir_idx] + log(1.10)
  inflection_idx <- which(pred_grid$CMB_Score > nadir_val & as.numeric(preds) >= target_link)[1]
  
  # Record results
  boot_results$nadir[i] <- nadir_val
  boot_results$risk_point_1.1[i] <- ifelse(is.na(inflection_idx), NA, pred_grid$CMB_Score[inflection_idx])
  
  # Logging
  if(i %% 100 == 0) cat("Iteration", i, "processed successfully.\n")
}

# 4. Summary & CI Calculation --------------------------------------------------
# Remove failed iterations (0 or NA)
valid_results <- boot_results %>% filter(nadir > 0 & !is.na(risk_point_1.1))

final_stats <- valid_results %>%
  summarise(
    Successful_Runs = n(),
    Nadir_Median = median(nadir),
    Nadir_95CI = paste0("[", round(quantile(nadir, 0.025), 2), "-", round(quantile(nadir, 0.975), 2), "]"),
    Threshold_Median = median(risk_point_1.1),
    Threshold_95CI = paste0("[", round(quantile(risk_point_1.1, 0.025), 2), "-", round(quantile(risk_point_1.1, 0.975), 2), "]")
  )

cat("\n--- BOOTSTRAP STABILITY SUMMARY ---\n")
print(final_stats)

