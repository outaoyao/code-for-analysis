    hypertension_status + work_status + MET_total + INDFMPIR + 
    sedentary_min,
  design = design_valid, 
  family = quasibinomial()
)

# 6. Comparative Assessment of Estimates ---------------------------------------
# Functional helper to extract spline coefficients and compute Odds Ratios (OR)
extract_robustness_metrics <- function(fit, label) {
  # Identifying the linear component of the spline
  linear_term <- grep("CMB_Score$", names(coef(fit)), value = TRUE)[1]
  beta <- coef(fit)[linear_term]
  se   <- sqrt(vcov(fit)[linear_term, linear_term])
  
  # Identifying the non-linear component (first spline tail)
  nonlinear_term <- grep("CMB_Score'", names(coef(fit)), value = TRUE)[1]
  beta_nl <- coef(fit)[nonlinear_term]
  se_nl   <- sqrt(vcov(fit)[nonlinear_term, nonlinear_term])
  
  data.frame(
    Cohort = label,
    Linear_OR = exp(beta),
    Linear_CI = paste0("(", round(exp(beta - 1.96 * se), 3), "-", round(exp(beta + 1.96 * se), 3), ")"),
    Nonlinear_Beta = round(beta_nl, 4),
    Nonlinear_P = round(2 * (1 - pnorm(abs(beta_nl / se_nl))), 4)
  )
}

# Compile and present comparison table
temporal_validation_results <- rbind(
  extract_robustness_metrics(fit_disc, "Discovery (2017-2020)"),
  extract_robustness_metrics(fit_valid, "Validation (2021-2023)")
)

